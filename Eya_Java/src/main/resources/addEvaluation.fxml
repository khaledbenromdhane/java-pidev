<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" prefWidth="600.0" prefHeight="700.0" style="-fx-background-color: #1a1a1a; -fx-padding: 20;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.AddEvaluationController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>

    <!-- Header -->
    <VBox style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-padding: 20;" spacing="15.0">
        <HBox alignment="CENTER_LEFT" spacing="20">
            <Label text="⭐ Nouvelle Évaluation" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #d4af37;">
                <font>
                    <Font name="System Bold" size="24.0" />
                </font>
            </Label>
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="timerLabel" text="⏱️ 00:00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #e67e22;" visible="false"/>
        </HBox>
        <Label text="Les questions seront générées dynamiquement par l'IA en fonction de la formation sélectionnée." style="-fx-font-size: 12px; -fx-text-fill: #999999; -fx-font-style: italic;" />
    </VBox>

    <!-- Formation Selection -->
    <VBox spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-padding: 15; -fx-border-left: 4px solid #3498db;">
        <Label text="📚 Sélectionnez la formation à évaluer" style="-fx-font-weight: bold; -fx-text-fill: #cccccc; -fx-font-size: 14px;" />
        <ComboBox fx:id="formationComboBox" promptText="Choisir une formation" style="-fx-control-inner-background: #3a3a3a; -fx-text-fill: white; -fx-padding: 8;" prefHeight="35.0" />
    </VBox>

    <!-- Questions Container -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: #1a1a1a; -fx-control-inner-background: #1a1a1a;">
        <VBox fx:id="questionsContainer" spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-padding: 15;" />
    </ScrollPane>

    <!-- Action Buttons -->
    <HBox spacing="10.0" alignment="CENTER_RIGHT" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-padding: 15;">
        <Button fx:id="saveBtn" text="✅ Enregistrer" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 10;" prefWidth="140.0" />
        <Button fx:id="cancelBtn" text="❌ Annuler" onAction="#handleCancel" style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-weight: bold; -fx-padding: 10;" prefWidth="140.0" />
    </HBox>
</VBox>
