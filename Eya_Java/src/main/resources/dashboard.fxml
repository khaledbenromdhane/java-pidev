<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.paint.Color?>
<?import javafx.scene.shape.Circle?>

<BorderPane fx:id="rootPane" prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #1a1a1a;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.DashboardController">
   <!-- Left Sidebar (Artis Event Design) -->
   <left>
      <VBox spacing="0" prefWidth="250.0" style="-fx-background-color: #0d0d12; -fx-border-right: 1px solid #222222;">
         <padding>
            <Insets top="30.0" />
         </padding>
         
         <!-- Logo Artis Event -->
         <HBox alignment="CENTER_LEFT" spacing="5.0" style="-fx-padding: 0 25 30 25;">
            <Label text="*" style="-fx-text-fill: #d4af37; -fx-font-size: 24px; -fx-font-weight: bold;" />
            <Label text="Artis" style="-fx-text-fill: white; -fx-font-size: 24px; -fx-font-weight: bold;" />
            <Label text="Event" style="-fx-text-fill: #d4af37; -fx-font-size: 24px; -fx-font-weight: bold;" />
         </HBox>

         <ScrollPane fitToWidth="true" hbarPolicy="NEVER" style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS" stylesheets="@style.css">
            <VBox spacing="5.0" style="-fx-padding: 0 15 0 15; -fx-background-color: transparent;">
               
               <!-- MAIN MENU -->
               <Label text="MAIN MENU" style="-fx-text-fill: #555558; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 10 0 10 10;" />
               
               <Button mnemonicParsing="false" styleClass="side-btn" text="Dashboard" prefWidth="220.0" onAction="#handleDashboardMenu" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Utilisateurs" prefWidth="220.0" />
               
               <!-- Evenements -->
               <Button mnemonicParsing="false" styleClass="side-btn" text="Evenements" prefWidth="220.0" />
               
               <Button mnemonicParsing="false" styleClass="side-btn" text="Blogs" prefWidth="220.0" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Galerie" prefWidth="220.0" />
               <!-- Formation (Active) -->
               <VBox spacing="2">
                   <Button fx:id="viewFormationsBtn" onAction="#handleViewFormations" mnemonicParsing="false" styleClass="side-btn, side-btn-active" text="Formation" prefWidth="220.0" />
                   <VBox spacing="8" style="-fx-padding: 8 0 10 40;">
                       <Label text="Formations" onMouseClicked="#handleViewFormations" style="-fx-text-fill: #d4af37; -fx-font-size: 13px; -fx-cursor: hand;" />
                       <Label text="Évaluations" onMouseClicked="#handleViewEvaluations" style="-fx-text-fill: #88888b; -fx-font-size: 13px; -fx-cursor: hand;" />
                   </VBox>
               </VBox>
               
               <Separator style="-fx-padding: 15 0; -fx-opacity: 0.2;" />
               
               <!-- COMPTE -->
               <Label text="COMPTE" style="-fx-text-fill: #555558; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 0 0 10 10;" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Mon Profil" prefWidth="220.0" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Modifier le Profil" prefWidth="220.0" />
               
               <!-- Logout Button -->
               <Button mnemonicParsing="false" styleClass="btn-logout-artis" text="Deconnexion" prefWidth="220.0">
                   <VBox.margin><Insets top="10" bottom="20"/></VBox.margin>
               </Button>
               
               <!-- SETTINGS -->
               <Label text="SETTINGS" style="-fx-text-fill: #555558; -fx-font-size: 11px; -fx-font-weight: bold; -fx-padding: 10 0 10 10;" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Analytics" prefWidth="220.0" />
               <Button mnemonicParsing="false" styleClass="side-btn" text="Settings" prefWidth="220.0" />
               
            </VBox>
         </ScrollPane>
      </VBox>
   </left>

   <!-- Main Content Area -->
   <center>
      <BorderPane style="-fx-background-color: #1a1a1a;">
         <!-- Top Bar -->
         <top>
            <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #1a1a1a; -fx-padding: 20; -fx-border-bottom: 1px solid #444444;">
               <Label text="📊 Tableau de Bord" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: white;">
                  <font>
                     <Font name="System Bold" size="28.0" />
                  </font>
               </Label>
               <Region HBox.hgrow="ALWAYS" />
                <HBox spacing="15.0" alignment="CENTER_RIGHT">
                  <TextField promptText="Rechercher..." style="-fx-control-inner-background: #3a3a3a; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-padding: 8; -fx-background-radius: 5;" prefWidth="150.0" />
                  <Button style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-font-size: 16px;" text="🔔" />
                  <Button fx:id="chatbotBtn" onAction="#handleChatbot" style="-fx-background-color: transparent; -fx-text-fill: #d4af37; -fx-font-size: 16px; -fx-cursor: hand;" text="💬" />
                  <Circle fx:id="userAvatar" radius="20.0" style="-fx-fill: #888888;" />
               </HBox>
            </HBox>
         </top>

         <!-- Main Content -->
         <center>
            <ScrollPane fitToWidth="true" style="-fx-background: #1a1a1a; -fx-background-color: #1a1a1a; -fx-control-inner-background: #1a1a1a;">
               <VBox spacing="25.0" style="-fx-padding: 30; -fx-background-color: #1a1a1a;">
                  <!-- Breadcrumb -->
                  <HBox spacing="10.0">
                     <Label text="🏠" style="-fx-font-size: 30px;" />
                     <Label text="Tableau de Bord" style="-fx-text-fill: #d4af37; -fx-font-size: 25px;" />
                  </HBox>

                  <!-- Statistics Cards -->
                  <VBox spacing="30.0">
                     <Label text="📈 Statistiques Générales" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: white;">
                        <font>
                           <Font name="System Bold" size="20.0" />
                        </font>
                     </Label>
                     <Region prefHeight="10.0" />
                     <GridPane hgap="20.0" vgap="15.0">
                        <columnConstraints>
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                           <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
                        </columnConstraints>
                        <rowConstraints>
                           <RowConstraints minHeight="10.0" prefHeight="100.0" vgrow="SOMETIMES" />
                        </rowConstraints>

                        <!-- Formations Card -->
                        <VBox fx:id="formationsCard" spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0); -fx-padding: 20; -fx-border-left: 4px solid #3498db;" GridPane.columnIndex="0">
                           <Label fx:id="formationsCountLabel" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #3498db;">
                              <font>
                                 <Font name="System Bold" size="40.0" />
                              </font>
                           </Label>
                           <Label text="Formations" style="-fx-font-size: 14px; -fx-text-fill: #cccccc;" />
                           <Label fx:id="formationsStatusLabel" text="Total" style="-fx-font-size: 13px; -fx-text-fill: #cccccc;" />
                        </VBox>

                        <!-- Evaluations Card -->
                        <VBox fx:id="evaluationsCard" spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0); -fx-padding: 20; -fx-border-left: 4px solid #e74c3c;" GridPane.columnIndex="1">
                           <Label fx:id="evaluationsCountLabel" text="0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;">
                              <font>
                                 <Font name="System Bold" size="40.0" />
                              </font>
                           </Label>
                           <Label text="Évaluations" style="-fx-font-size: 14px; -fx-text-fill: #cccccc;" />
                           <Label fx:id="evaluationsStatusLabel" text="Total" style="-fx-font-size: 13px; -fx-text-fill: #cccccc;" />
                        </VBox>

                        <!-- Average Rating Card -->
                        <VBox fx:id="averageRatingCard" spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0); -fx-padding: 20; -fx-border-left: 4px solid #d4af37;" GridPane.columnIndex="2">
                           <Label fx:id="averageRatingLabel" text="0.0" style="-fx-font-size: 40px; -fx-font-weight: bold; -fx-text-fill: #d4af37;">
                              <font>
                                 <Font name="System Bold" size="40.0" />
                              </font>
                           </Label>
                           <Label text="Note Moyenne" style="-fx-font-size: 14px; -fx-text-fill: #cccccc;" />
                           <Label text="/5" style="-fx-font-size: 13px; -fx-text-fill: #cccccc;" />
                        </VBox>
                      </GridPane>
                   </VBox>

                   <!-- Quick Actions / Gestion Section -->
                   <Region prefHeight="20.0" />
                   <VBox spacing="30.0">
                      <Label text="⚡ GESTION" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #d4af37;">
                         <font>
                            <Font name="System Bold" size="16.0" />
                         </font>
                      </Label>
                      <HBox spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0); -fx-padding: 15;">
                         <Button fx:id="viewFormationsBtn" mnemonicParsing="false" onAction="#handleViewFormations" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 12px; -fx-padding: 10; -fx-content-display: LEFT; -fx-border-bottom: 2px solid #3498db;" text="📚 Formations">
                            <font>
                               <Font name="System" size="12.0" />
                            </font>
                         </Button>
                         <Button fx:id="addFormationBtn" mnemonicParsing="false" onAction="#handleAddFormation" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 12px; -fx-padding: 10; -fx-content-display: LEFT; -fx-border-bottom: 2px solid #2ecc71;" text="➕ Nouvelle Formation">
                            <font>
                               <Font name="System" size="12.0" />
                            </font>
                         </Button>
                         <Button fx:id="viewEvaluationsBtn" mnemonicParsing="false" onAction="#handleViewEvaluations" prefHeight="40.0" prefWidth="150.0" style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 12px; -fx-padding: 10; -fx-content-display: LEFT; -fx-border-bottom: 2px solid #e74c3c;" text="📊 Évaluations">
                            <font>
                               <Font name="System" size="12.0" />
                            </font>
                         </Button>
                         <Button fx:id="viewScoresBtn" mnemonicParsing="false" onAction="#handleViewEvaluations" prefHeight="40.0" prefWidth="180.0" style="-fx-background-color: transparent; -fx-text-fill: #cccccc; -fx-font-size: 12px; -fx-padding: 10; -fx-content-display: LEFT; -fx-border-bottom: 2px solid #f39c12;" text="📜 Certificats &amp; Scores">
                            <font>
                               <Font name="System" size="12.0" />
                            </font>
                         </Button>
                      </HBox>
                   </VBox>

                   <!-- Database Status -->
                  <VBox spacing="30.0">
                     <Label text="🗄️ État du Système" style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-text-fill: white;">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     <HBox fx:id="databaseStatusContainer" spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0); -fx-padding: 20;">
                        <Label fx:id="databaseStatusLabel" text="🔄 Vérification de la connexion..." style="-fx-font-size: 14px; -fx-text-fill: #cccccc;" />
                        <Label fx:id="databaseStatusIcon" text="⏳" style="-fx-font-size: 16px;" />
                     </HBox>
                  </VBox>

                  <!-- Recent Activities -->
                  <VBox spacing="30.0">
                     <Label text="🕒 Dernières Activités" style="-fx-font-size: 25px; -fx-font-weight: bold; -fx-text-fill: white;">
                        <font>
                           <Font name="System Bold" size="18.0" />
                        </font>
                     </Label>
                     <VBox fx:id="recentActivitiesContainer" spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-background-radius: 10; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.5), 15, 0, 0, 0);">
                        <padding>
                           <Insets bottom="15.0" left="15.0" right="15.0" top="15.0" />
                        </padding>
                        <Label fx:id="noActivitiesLabel" text="Aucune activité récente" style="-fx-text-fill: #888888; -fx-font-style: italic;" />
                     </VBox>
                  </VBox>
               </VBox>
            </ScrollPane>
         </center>

         <!-- Bottom Bar -->
         <bottom>
            <HBox alignment="CENTER_RIGHT" spacing="15.0" style="-fx-background-color: #1a1a1a; -fx-padding: 15; -fx-border-top: 1px solid #444444;">
               <Label fx:id="footerLabel" text="© 2026 Formation Manager - Système de Gestion des Formations" style="-fx-text-fill: #888888; -fx-font-size: 11px;" HBox.hgrow="ALWAYS" />
               <Button fx:id="refreshBtn" mnemonicParsing="false" onAction="#handleRefresh" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-background-radius: 5; -fx-font-weight: bold;" text="🔄 Actualiser">
                  <font>
                     <Font name="System Bold" size="11.0" />
                  </font>
               </Button>
            </HBox>
         </bottom>
      </BorderPane>
   </center>
</BorderPane>
