<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" prefWidth="800.0" prefHeight="450.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.ViewEvaluationsController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>
    <Label text="📜 Gestion des Certificats &amp; Scores" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>
    <TableView fx:id="evaluationsTable" prefHeight="300.0" style="-fx-background-radius: 10;">
        <columns>
            <TableColumn fx:id="formationCol" text="Formation" prefWidth="150.0" />
            <TableColumn fx:id="titreCol" text="Titre" prefWidth="150.0" />
            <TableColumn fx:id="noteCol" text="Note" prefWidth="60.0" />
            <TableColumn fx:id="commentaireCol" text="Commentaire" prefWidth="280.0" />
            <TableColumn fx:id="actionsCol" text="Actions" prefWidth="80.0" />
        </columns>
    </TableView>
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button fx:id="closeBtn" text="Fermer" onAction="#handleClose" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 8;" prefWidth="100.0" />
    </HBox>
</VBox>
