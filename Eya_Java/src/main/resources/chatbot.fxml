<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox prefHeight="600.0" prefWidth="450.0" spacing="0" style="-fx-background-color: #1a1a1a; -fx-border-color: #d4af37; -fx-border-width: 2;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.ChatbotController">
   <children>
      <!-- Header -->
      <HBox alignment="CENTER_LEFT" prefHeight="60.0" spacing="15.0" style="-fx-background-color: #2a2a2a; -fx-padding: 0 20;">
         <children>
            <Label text="🤖" style="-fx-font-size: 24px;" />
            <VBox alignment="CENTER_LEFT">
               <children>
                  <Label text="Assistant IA" textFill="#d4af37">
                     <font>
                        <Font name="System Bold" size="16.0" />
                     </font>
                  </Label>
                  <Label text="En ligne" textFill="#2ecc71" style="-fx-font-size: 10px;" />
               </children>
            </VBox>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="closeBtn" mnemonicParsing="false" onAction="#handleClose" style="-fx-background-color: transparent; -fx-text-fill: #888888; -fx-font-size: 18px; -fx-cursor: hand;" text="✕" />
         </children>
      </HBox>

      <!-- Chat Area -->
      <ScrollPane fx:id="scrollPane" fitToWidth="true" style="-fx-background: #1a1a1a; -fx-background-color: #1a1a1a; -fx-padding: 10;" VBox.vgrow="ALWAYS">
         <content>
            <VBox fx:id="chatContainer" spacing="15.0" style="-fx-background-color: #1a1a1a;">
               <padding>
                  <Insets bottom="10.0" left="10.0" right="10.0" top="10.0" />
               </padding>
            </VBox>
         </content>
      </ScrollPane>

      <!-- Input Area -->
      <HBox alignment="CENTER" prefHeight="70.0" spacing="10.0" style="-fx-background-color: #2a2a2a; -fx-padding: 15;">
         <children>
            <TextField fx:id="inputField" onAction="#handleSend" promptText="Posez votre question ici..." HBox.hgrow="ALWAYS" style="-fx-background-color: #3a3a3a; -fx-text-fill: white; -fx-prompt-text-fill: #888888; -fx-background-radius: 20; -fx-padding: 10 15;" />
            <Button fx:id="sendBtn" mnemonicParsing="false" onAction="#handleSend" prefHeight="40.0" prefWidth="40.0" style="-fx-background-color: #d4af37; -fx-background-radius: 20; -fx-cursor: hand;" text="✈" textFill="BLACK">
               <font>
                  <Font name="System Bold" size="14.0" />
               </font>
            </Button>
         </children>
      </HBox>
   </children>
</VBox>
