<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" prefHeight="400.0" prefWidth="350.0" spacing="20.0" style="-fx-background-color: #f4f4f9; -fx-padding: 20;" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.QRCodeDisplayController">
   <children>
      <Label text="QR Code de Formation" textFill="#2c3e50">
         <font>
            <Font name="System Bold" size="18.0" />
         </font>
      </Label>
      <Label fx:id="formationNameLabel" text="Nom de la Formation" textFill="#34495e">
         <font>
            <Font size="14.0" />
         </font>
      </Label>
      <ImageView fx:id="qrImageView" fitHeight="250.0" fitWidth="250.0" pickOnBounds="true" preserveRatio="true" style="-fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.2), 10, 0, 0, 0);" />
      <Label text="Scannez pour accéder aux détails" textFill="#7f8c8d">
         <font>
            <Font name="System Italic" size="12.0" />
         </font>
      </Label>
   </children>
</VBox>
