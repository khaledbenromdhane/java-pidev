<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox spacing="15.0" prefWidth="500.0" prefHeight="500.0" style="-fx-background-color: #f4f4f4; -fx-padding: 20;" xmlns="http://javafx.com/javafx/11.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="esprit.tn.controllers.AddEvaluationController">
    <padding>
        <Insets top="20.0" right="20.0" bottom="20.0" left="20.0" />
    </padding>
    <Label text="⭐ Nouvelle Évaluation" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;">
        <font>
            <Font name="System Bold" size="20.0" />
        </font>
    </Label>
    <VBox spacing="10.0">
        <Label text="Sélectionnez la formation à évaluer *" style="-fx-font-weight: bold;" />
        <ComboBox fx:id="formationComboBox" promptText="Choisir une formation" />
    </VBox>
    <VBox fx:id="questionsContainer" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 15;" />
    <HBox spacing="10.0" alignment="CENTER_RIGHT">
        <Button fx:id="saveBtn" text="Enregistrer" onAction="#handleSave" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 8;" prefWidth="120.0" />
        <Button fx:id="cancelBtn" text="Annuler" onAction="#handleCancel" style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-background-radius: 8;" prefWidth="120.0" />
    </HBox>
</VBox>

