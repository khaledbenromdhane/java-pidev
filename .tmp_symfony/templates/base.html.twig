<!doctype html>
<html class="no-js" lang="fr">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="ie=edge">
    <title>{% block title %}ArtVista - Museum & Art Gallery{% endblock %}</title>
    <meta name="description" content="ArtVista - Museum & Art Gallery">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <link rel="icon" type="image/png" sizes="32x32" href="{{ asset('assets/img/favicons/favicon.png') }}">

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Jost:ital,wght@0,100..900;1,100..900&family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="{{ asset('assets/css/bootstrap.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/all.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/magnific-popup.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/slick.min.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/odometer.css') }}">
    <link rel="stylesheet" href="{{ asset('assets/css/style.css') }}">

    <!-- Chart.js (statistiques admin) -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    {% block stylesheets %}{% endblock %}

    <style>
        /* ── Avatar Profile Menu ── */
        .user-avatar-btn {
            display: flex; align-items: center; gap: 8px;
            background: none; border: none; cursor: pointer;
            color: inherit; text-decoration: none;
        }
        .user-avatar-btn img {
            width: 36px; height: 36px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #d4a574;
        }
        .user-avatar-btn .user-name {
            font-size: 14px; font-weight: 500;
        }
        .profile-dropdown {
            min-width: 220px;
            border: none;
            box-shadow: 0 8px 30px rgba(0,0,0,0.15);
            border-radius: 12px;
            overflow: hidden;
        }
        .profile-dropdown .dropdown-header {
            background: linear-gradient(135deg, #d4a574, #c4924e);
            color: white; padding: 16px;
        }
        .profile-dropdown .dropdown-header img {
            width: 55px; height: 55px;
            border-radius: 50%; object-fit: cover;
            border: 3px solid rgba(255,255,255,0.5);
            margin-bottom: 8px;
        }
        .profile-dropdown .dropdown-item {
            padding: 10px 16px; font-size: 14px;
            display: flex; align-items: center; gap: 10px;
        }
        .profile-dropdown .dropdown-item:hover {
            background-color: #f8f4ef; color: #d4a574;
        }
        .profile-dropdown .dropdown-item i { width: 16px; color: #d4a574; }
        .profile-dropdown .dropdown-item.text-danger i { color: #dc3545; }
    </style>
</head>

<body>
    <!-- Curseur -->
    <div class="cursor"></div>
    <div class="cursor-follower"></div>

    <!-- Preloader -->
    <div class="preloader">
        <div class="preloader-inner">
            <img src="{{ asset('assets/img/logo-white.svg') }}" alt="ArtVista">
            <span class="loader"></span>
        </div>
    </div>

    <!-- Sidemenu -->
    <div class="sidemenu-wrapper">
        <div class="sidemenu-content">
            <button class="closeButton sideMenuCls"><i class="fas fa-times"></i></button>

            {# ── Auth dans sidemenu ── #}
            <div class="widget footer-widget mb-4">
                <h4 class="widget_title text-white mb-3">Mon Compte</h4>
                {% if app.user %}
                    <div class="d-flex align-items-center gap-2 mb-3">
                        <img src="{{ app.user.avatarUrl }}"
                             alt="Avatar"
                             style="width:45px;height:45px;border-radius:50%;object-fit:cover;border:2px solid #d4a574;">
                        <div>
                            <div class="text-white fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                            <small class="text-muted">{{ app.user.email }}</small>
                        </div>
                    </div>
                    <a href="{{ path('app_profile') }}" class="btn w-100 mb-2">
                        <i class="fas fa-user me-2"></i>Mon Profil
                    </a>
                    <a href="{{ path('app_logout') }}" class="btn style2 w-100">
                        <i class="fas fa-sign-out-alt me-2"></i>Déconnexion
                    </a>
                {% else %}
                    <a href="{{ path('app_login') }}" class="btn w-100 mb-2">
                        <i class="fas fa-sign-in-alt me-2"></i>Connexion
                    </a>
                    <a href="{{ path('app_register') }}" class="btn style2 w-100">
                        <i class="fas fa-user-plus me-2"></i>Inscription
                    </a>
                {% endif %}
            </div>

            <div class="widget footer-widget">
                <div class="widget widget-about footer-widget">
                    <div class="footer-logo">
                        <a href="{{ path('app_home') }}"><img src="{{ asset('assets/img/logo-white.svg') }}" alt="logo"></a>
                    </div>
                    <p class="about-text mb-4 text-white">
                        Découvrez l'art et la culture à travers notre musée.
                    </p>
                    <div class="social-btn style2 mt-30">
                        <a href="https://facebook.com/"><i class="fab fa-facebook-f"></i></a>
                        <a href="https://twitter.com/"><i class="fab fa-twitter"></i></a>
                        <a href="https://linkedin.com/"><i class="fab fa-linkedin-in"></i></a>
                        <a href="https://instagram.com/"><i class="fab fa-instagram"></i></a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Mobile Menu -->
    <div class="mobile-menu-wrapper">
        <div class="mobile-menu-area text-center">
            <button class="menu-toggle"><i class="fas fa-times"></i></button>
            <div class="mobile-logo">
                <a href="{{ path('app_home') }}"><img src="{{ asset('assets/img/logo-white.svg') }}" alt="ArtVista"></a>
            </div>
            <div class="mobile-menu">
                <ul>
                    {% if app.user %}
                        <li>
                            <a href="{{ path('app_profile') }}">
                                <i class="fas fa-user-circle me-2"></i>Mon Profil
                            </a>
                        </li>
                        {% if is_granted('ROLE_ADMIN') %}
                            <li><a href="{{ path('app_admin_dashboard') }}"><i class="fas fa-tachometer-alt me-2"></i>Administration</a></li>
                        {% endif %}
                        <li><a href="{{ path('app_logout') }}"><i class="fas fa-sign-out-alt me-2"></i>Déconnexion</a></li>
                    {% else %}
                        <li><a href="{{ path('app_login') }}"><i class="fas fa-sign-in-alt me-2"></i>Connexion</a></li>
                        <li><a href="{{ path('app_register') }}"><i class="fas fa-user-plus me-2"></i>Inscription</a></li>
                    {% endif %}
                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                </ul>
            </div>
        </div>
    </div>

    <!--==============================
    Header
    ==============================-->
    <header class="nav-header header-layout1">
        <div class="header-top d-md-block d-none">
            <div class="container">
                <div class="row justify-content-center justify-content-lg-between align-items-center gy-2">
                    <div class="col-auto">
                        <div class="header-links">
                            <ul>
                                <li><i class="fas fa-phone-alt"></i><a href="tel:+21600000000">+216 00 000 000</a></li>
                                <li><i class="far fa-envelope"></i><a href="mailto:contact@artvista.tn">contact@artvista.tn</a></li>
                                <li><i class="far fa-clock"></i>Lun - Ven: 9h00 - 17h00</li>
                            </ul>
                        </div>
                    </div>
                    <div class="col-auto d-none d-lg-block">
                        <div class="header-links header-links-right">
                            <ul>
                                {# ── Bloc AUTH ── #}
                                <li>
                                    {% if app.user %}
                                        {# Utilisateur connecté → Dropdown profil avec avatar #}
                                        <div class="dropdown">
                                            <a class="user-avatar-btn dropdown-toggle"
                                               href="#"
                                               role="button"
                                               data-bs-toggle="dropdown"
                                               aria-expanded="false">
                                                <img src="{{ app.user.avatarUrl }}"
                                                     alt="{{ app.user.prenom }}"
                                                     onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                <span class="user-name">{{ app.user.prenom }}</span>
                                                <i class="fas fa-chevron-down ms-1" style="font-size:10px;"></i>
                                            </a>
                                            <ul class="dropdown-menu dropdown-menu-end profile-dropdown">
                                                {# En-tête avec avatar et nom #}
                                                <li>
                                                    <div class="dropdown-header text-center">
                                                        <img src="{{ app.user.avatarUrl }}"
                                                             alt="{{ app.user.prenom }}"
                                                             onerror="this.src='https://ui-avatars.com/api/?name={{ app.user.prenom|url_encode }}+{{ app.user.nom|url_encode }}&background=d4a574&color=fff'">
                                                        <div class="fw-bold">{{ app.user.prenom }} {{ app.user.nom }}</div>
                                                        <small style="opacity:.8;">{{ app.user.email }}</small>
                                                        <div class="mt-1">
                                                            {% for role in app.user.roles %}
                                                                {% if role != 'ROLE_USER' %}
                                                                    <span class="badge" style="background:rgba(255,255,255,0.3);font-size:10px;">
                                                                        {{ role|replace({'ROLE_': ''}) }}
                                                                    </span>
                                                                {% endif %}
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                </li>
                                                <li><hr class="dropdown-divider m-0"></li>
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_profile') }}">
                                                        <i class="fas fa-user"></i> Mon Profil
                                                    </a>
                                                </li>
                                                <li>
                                                    <a class="dropdown-item" href="{{ path('app_profile_edit') }}">
                                                        <i class="fas fa-edit"></i> Modifier le profil
                                                    </a>
                                                </li>
                                                {% if is_granted('ROLE_ADMIN') %}
                                                    <li><hr class="dropdown-divider"></li>
                                                    <li>
                                                        <a class="dropdown-item" href="{{ path('app_admin_dashboard') }}">
                                                            <i class="fas fa-tachometer-alt"></i> Administration
                                                        </a>
                                                    </li>
                                                    <li>
                                                        <a class="dropdown-item" href="{{ path('app_admin_users_index') }}">
                                                            <i class="fas fa-users-cog"></i> Gestion utilisateurs
                                                        </a>
                                                    </li>
                                                {% endif %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li>
                                                    <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                                                        <i class="fas fa-sign-out-alt"></i> Déconnexion
                                                    </a>
                                                </li>
                                            </ul>
                                        </div>
                                    {% else %}
                                        {# Non connecté → Connexion / Inscription #}
                                        <i class="fas fa-user"></i>
                                        <a href="{{ path('app_login') }}">Connexion</a>
                                        <span style="margin:0 5px;">|</span>
                                        <a href="{{ path('app_register') }}">Inscription</a>
                                    {% endif %}
                                </li>
                                <li>
                                    <button type="button" class="sidebar-btn sideMenuToggler">
                                        <span class="line"></span>
                                    </button>
                                </li>
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="sticky-wrapper">
            <div class="menu-area">
                <div class="container">
                    <div class="row align-items-center justify-content-between">
                        <div class="col-auto">
                            <div class="header-logo">
                                <a href="{{ path('app_home') }}">
                                    <img src="{{ asset('assets/img/logo.svg') }}" alt="ArtVista">
                                </a>
                            </div>
                        </div>
                        <div class="col-auto">
                            <nav class="main-menu d-none d-lg-inline-block">
                                <ul>
                                    <li><a href="{{ path('app_front_index') }}">Accueil</a></li>
                                    <li><a href="{{ path('app_front_oeuvre') }}">Œuvres</a></li>
                                    <li><a href="{{ path('app_evenement_index') }}">Événements</a></li>
                                    <li><a href="{{ path('blog_publication_index') }}">Blog</a></li>
                                    <li><a href="{{ path('app_formation_front') }}">Formation</a></li>
                                </ul>
                            </nav>
                        </div>
                        <div class="col-auto d-flex align-items-center gap-3">
                            <button type="button" class="icon-btn sideMenuToggler d-lg-none">
                                <span class="line"></span>
                            </button>
                            <button type="button" class="menu-toggle d-lg-none">
                                <i class="fas fa-bars"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!--==============================
    Page Content
    ==============================-->
    <div id="page-wrapper">
        {% block body %}{% endblock %}
    </div>

    <!--==============================
    Footer
    ==============================-->
    <footer class="footer-wrapper footer-layout1 overflow-hidden">
        <div class="container">
            <div class="footer-top">
                <div class="row align-items-center justify-content-between">
                    <div class="col-sm-auto">
                        <div class="footer-logo mb-40 mb-sm-0">
                            <a href="{{ path('app_home') }}">
                                <img src="{{ asset('assets/img/logo-white.svg') }}" alt="ArtVista">
                            </a>
                        </div>
                    </div>
                    <div class="col-sm-auto">
                        <div class="social-btn style2">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                            <a href="#"><i class="fab fa-behance"></i></a>
                            <a href="#"><i class="fab fa-youtube"></i></a>
                        </div>
                    </div>
                </div>
            </div>
            <div class="widget-area">
                <div class="row justify-content-between">
                    <div class="col-md-6 col-xl-3 col-lg-4">
                        <div class="widget footer-widget">
                            <div class="widget-contact">
                                <h3 class="widget_title">Informations</h3>
                                <ul class="contact-info-list">
                                    <li>Tél: +216 XX XXX XXX</li>
                                    <li>Email: contact@artvista.tn</li>
                                    <li>Adresse: Tunis, Tunisie</li>
                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-xl-auto col-lg-4">
                        <div class="widget widget_nav_menu footer-widget">
                            <h3 class="widget_title">Navigation</h3>
                            <div class="menu-all-pages-container">
                                <ul class="menu">
                                    {% if app.user %}
                                        <li><a href="{{ path('app_profile') }}">Mon Profil</a></li>
                                        <li><a href="{{ path('app_logout') }}">Déconnexion</a></li>
                                    {% else %}
                                        <li><a href="{{ path('app_login') }}">Connexion</a></li>
                                        <li><a href="{{ path('app_register') }}">Inscription</a></li>
                                    {% endif %}

                                </ul>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6 col-lg-4">
                        <div class="widget footer-widget">
                            <h3 class="widget_title">Newsletter</h3>
                            <p class="footer-text">Restez informé de nos expositions.</p>
                            <form class="newsletter-form">
                                <div class="form-group">
                                    <input class="form-control" type="email" placeholder="Votre email" required>
                                </div>
                                <button type="submit" class="btn">S'ABONNER</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="copyright-wrap text-center">
            <div class="container">
                <p class="copyright-text text-white">
                    © {{ "now"|date("Y") }} <a href="#">ArtVista.</a> Tous droits réservés.
                </p>
            </div>
        </div>
    </footer>

    <!-- Scroll To Top -->
    <div class="scroll-top">
        <svg class="progress-circle svg-content" width="100%" height="100%" viewBox="-1 -1 102 102">
            <path d="M50,1 a49,49 0 0,1 0,98 a49,49 0 0,1 0,-98"
                  style="stroke-dasharray:307.919;stroke-dashoffset:307.919;"></path>
        </svg>
    </div>

    <!-- JS -->
    <script src="{{ asset('assets/js/vendor/jquery-3.7.1.min.js') }}"></script>
    <script src="{{ asset('assets/js/slick.min.js') }}"></script>
    <script src="{{ asset('assets/js/bootstrap.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.magnific-popup.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery.counterup.min.js') }}"></script>
    <script src="{{ asset('assets/js/jquery-ui.min.js') }}"></script>
    <script src="{{ asset('assets/js/imagesloaded.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/js/isotope.pkgd.min.js') }}"></script>
    <script src="{{ asset('assets/js/ScrollTrigger.min.js') }}"></script>
    <script src="{{ asset('assets/js/main.js') }}"></script>

    {% block javascripts %}{% endblock %}
</body>
</html>
