                <div id="qr-code-container" style="display:inline-block;padding:1rem;background:#fff;border-radius:var(--radius);"></div>
                <div id="qr-details" style="margin-top:1rem;text-align:left;font-size:.85rem;color:var(--text-secondary);">
                </div>
            </div>
            <div class="modal-footer">
