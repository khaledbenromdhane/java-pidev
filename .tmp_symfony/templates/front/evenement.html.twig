{% block javascripts %}
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function () {

    /* ══════════════════════════════════════════════════════
       MOVE MODALS OUT OF #smooth-content
    ══════════════════════════════════════════════════════ */
    var pmEl = document.getElementById('participateModal');
    var emEl = document.getElementById('editParticipationModal');
    var qrEl = document.getElementById('qrcodeModal');
    if (pmEl) document.body.appendChild(pmEl);
    if (emEl) document.body.appendChild(emEl);
    if (qrEl) document.body.appendChild(qrEl);

    /* Pause ScrollSmoother while any modal is open */
    var smoother = (typeof ScrollSmoother !== 'undefined') ? ScrollSmoother.get() : null;
    document.querySelectorAll('.modal').forEach(function (m) {
        m.addEventListener('shown.bs.modal', function () {
            if (smoother) smoother.paused(true);
        });
        m.addEventListener('hidden.bs.modal', function () {
            if (smoother) smoother.paused(false);
        });
    });

    var pmModal = new bootstrap.Modal(pmEl);
    var emModal = new bootstrap.Modal(emEl);
    var qrModal = new bootstrap.Modal(qrEl);
    var today   = new Date().toISOString().split('T')[0];

    /* ═══ DYNAMIC CLIENT-SIDE SEARCH (instant filter) ═══ */
    var searchInput = document.getElementById('frontSearchInput');
    var searchBtn   = document.getElementById('frontSearchBtn');
    var searchClear = document.getElementById('frontSearchClear');
    var searchInfo  = document.getElementById('frontSearchInfo');
    var searchTerm  = document.getElementById('frontSearchTerm');
    var searchCount = document.getElementById('frontSearchCount');
    var evtGrid     = document.getElementById('evtGrid');
    var allCards    = []; // Store all event cards for filtering

    // Store all cards on page load
    if (evtGrid) {
        allCards = Array.from(evtGrid.querySelectorAll('.evt-card'));
    }

    function doLiveSearch() {
        var q = searchInput.value.trim().toLowerCase();
        
        if (!evtGrid || allCards.length === 0) return;

        var visibleCount = 0;

        // Filter cards based on search query (NAME ONLY)
        allCards.forEach(function(card) {
            var eventName = card.querySelector('.evt-title a')?.textContent.toLowerCase() || '';
            
            // Check if event name matches the search query
            var matches = !q || eventName.includes(q);
            
            if (matches) {
                card.style.display = '';
                visibleCount++;
            } else {
                card.style.display = 'none';
            }
        });

        // Update search info
        if (q) {
            searchInfo.style.display = 'block';
            searchTerm.textContent = q;
            searchCount.textContent = visibleCount;
            searchClear.style.display = '';
        } else {
            searchInfo.style.display = 'none';
            searchClear.style.display = 'none';
        }

        // Show "no results" message if needed
        var existingEmpty = evtGrid.querySelector('.empty-state');
        if (existingEmpty) existingEmpty.remove();

        if (visibleCount === 0) {
            var emptyDiv = document.createElement('div');
            emptyDiv.className = 'empty-state';
            emptyDiv.style.gridColumn = '1/-1';
            emptyDiv.innerHTML = '<i class="fas fa-calendar-xmark"></i>' +
                '<h4>Aucun événement trouvé</h4>' +
                '<p>Aucun événement ne correspond à votre recherche "' + escapeHtml(q) + '".</p>';
            evtGrid.appendChild(emptyDiv);
        }
    }

    // Live search on every keystroke (instant filter)
    if (searchInput) {
        searchInput.addEventListener('input', doLiveSearch);
        
        // Run initial search if there's a query in the input
        if (searchInput.value.trim()) {
            doLiveSearch();
        }
    }
    
    if (searchBtn) searchBtn.addEventListener('click', doLiveSearch);
    
    if (searchClear) {
        searchClear.addEventListener('click', function () {
            searchInput.value = '';
            doLiveSearch();
        });
    }

    /* ═══ SORT PILLS (reload page with sort params) ═══ */
    var sortBar = document.getElementById('frontSortBar');
    var currentSort  = sortBar ? sortBar.getAttribute('data-current-sort') : 'date';
    var currentOrder = sortBar ? sortBar.getAttribute('data-current-order') : 'ASC';
    
    document.querySelectorAll('#frontSortBar .sort-pill').forEach(function (pill) {
        pill.addEventListener('click', function (e) {
            e.preventDefault();
            var key = this.getAttribute('data-sort-key');
            var newOrder = 'ASC';
            
            if (currentSort === key) {
                newOrder = currentOrder === 'ASC' ? 'DESC' : 'ASC';
            } else {
                newOrder = key === 'date' ? 'ASC' : 'ASC';
            }

            // Build URL with sort parameters (keep search query if present)
            var q = searchInput ? searchInput.value.trim() : '';
            var url = '/evenement?sort=' + encodeURIComponent(key) + '&order=' + encodeURIComponent(newOrder);
            if (q) {
                url += '&q=' + encodeURIComponent(q);
            }
            
            window.location.href = url;
        });
    });

    /* ═══ UTILITY: Escape HTML ═══ */
    function escapeHtml(str) {
        var d = document.createElement('div');
        d.appendChild(document.createTextNode(str || ''));
        return d.innerHTML;
    }

    /* ═══ UTILITY: Strip accented characters for QR code compatibility ═══ */
    function stripAccents(str) {
        if (!str) return '';
        var accents    = 'ÀÁÂÃÄÅàáâãäåÈÉÊËèéêëÌÍÎÏìíîïÒÓÔÕÖØòóôõöøÙÚÛÜùúûüÇçÑñÝýÿ';
        var asciiChars = 'AAAAAAaaaaaaEEEEeeeeIIIIiiiiOOOOOOooooooUUUUuuuuCcNnYyy';
        var result = '';
        for (var i = 0; i < str.length; i++) {
            var idx = accents.indexOf(str[i]);
            result += idx !== -1 ? asciiChars[idx] : str[i];
        }
        return result;
    }

    /* ═══ STRIPE: Toggle info banner + button text ═══ */
    var currentEventPrix = 0; // Will be set when modal opens
    function updateStripeInfo() {
        var modeSelect = document.getElementById('pm-mode');
        var stripeInfo = document.getElementById('pm-stripe-info');
        var submitIcon = document.querySelector('#pm-submit-btn i');
        var submitText = document.getElementById('pm-submit-text');

        if (modeSelect && modeSelect.value === 'Carte') {
            if (stripeInfo) {
                var priceText = currentEventPrix ? parseFloat(currentEventPrix).toFixed(2).replace('.', ',') : '0,00';
                stripeInfo.innerHTML = '<i class="fab fa-stripe me-1" style="font-size:1.1em;"></i>Vous serez redirig\u00e9 vers <strong>Stripe</strong> pour effectuer le paiement s\u00e9curis\u00e9 par carte. \u2014 <span style="color:#a5b4fc">' + priceText + ' \u20ac / place</span>';
                stripeInfo.style.display = 'block';
            }
            if (submitIcon) submitIcon.className = 'fab fa-stripe me-1';
            if (submitText) submitText.textContent = 'Payer avec Stripe';
        } else {
            if (stripeInfo) stripeInfo.style.display = 'none';
            if (submitIcon) submitIcon.className = 'fas fa-check me-1';
            if (submitText) submitText.textContent = 'Valider';
        }
    }

    // Listen for payment mode changes
    var pmModeSelect = document.getElementById('pm-mode');
    if (pmModeSelect) {
        pmModeSelect.addEventListener('change', updateStripeInfo);
    }

    /* ═══ BIND BUTTONS on cards (initial page load) ═══ */
    function bindCardButtons() {
        /* Create modal */
        document.querySelectorAll('.btn-open-participate').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d = this.dataset;
                var eventDate = d.eventDate || '';

                // Check: today must be on or before event day
                if (eventDate && today > eventDate) {
                    alert('Vous ne pouvez plus participer à cet événement car sa date est dépassée.');
                    return;
                }

                document.getElementById('pm-event-id').value         = d.eventId;
                document.getElementById('pm-event-name').textContent = d.eventNom;
                document.getElementById('pm-nbr').value = 1;
                document.getElementById('pm-mode').value = '';

                // Store current event price for Stripe info display
                currentEventPrix = d.eventPrix || 0;

                // Clear previous AJAX errors
                clearFormErrors(document.getElementById('participateForm'));

                var pg   = document.getElementById('pm-paiement-group');
                var paid = d.eventPaiement === '1';
                pg.style.display = paid ? 'block' : 'none';
                document.getElementById('pm-mode').required = paid;

                // Reset Stripe info
                updateStripeInfo();

                pmModal.show();
            });
        });

        /* Edit modal */
        document.querySelectorAll('.btn-open-edit').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d    = this.dataset;
                var form = document.getElementById('editParticipationForm');
                form.action = '/evenement/participation/' + d.participationId + '/modifier';

                var eventDate = d.eventDate || '';
                if (eventDate && today > eventDate) {
                    alert('Vous ne pouvez plus modifier cette participation car la date de l\'événement est dépassée.');
                    return;
                }

                document.getElementById('em-event-id').value         = d.eventId;
                document.getElementById('em-event-name').textContent = d.eventNom;
                document.getElementById('em-nbr').value = d.nbr || 1;
                document.getElementById('em-mode').value = d.mode || '';

                // Clear previous AJAX errors
                clearFormErrors(document.getElementById('editParticipationForm'));

                var pg   = document.getElementById('em-paiement-group');
                var paid = d.eventPaiement === '1';
                pg.style.display = paid ? 'block' : 'none';
                document.getElementById('em-mode').required = paid;

                emModal.show();
            });
        });

        /* QR Code modal (participation — shows participation + event details) */
        document.querySelectorAll('.btn-open-part-qr').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var d = this.dataset;
                document.getElementById('qr-event-name').textContent = d.eventNom + ' — Participation #' + d.participationId;

                var qrContainer = document.getElementById('qr-code-container');
                qrContainer.innerHTML = '';

                // Build QR text with ASCII-safe characters (accents break QRCode.js)
                var sNom   = stripAccents(d.eventNom   || '');
                var sType  = stripAccents(d.eventType  || '');
                var sLieu  = stripAccents(d.eventLieu  || '');
                var sStatut = stripAccents(d.partStatut || '');
                var sMode  = stripAccents(d.partMode   || '');

                var qrText = 'SCAN:' + d.participationId
                    + '\nCONFIRMATION DE PARTICIPATION'
                    + '\nParticipation #' + d.participationId
                    + '\nDate: ' + (d.partDate || '')
                    + '\nPlaces: ' + (d.partNbr || '')
                    + '\nStatut: ' + sStatut
                    + '\nPaiement: ' + sMode
                    + '\nEvenement: ' + sNom
                    + '\nType: ' + sType
                    + '\nDate evt: ' + (d.eventDate || '')
                    + '\nHeure: ' + (d.eventHeure || '')
                    + '\nLieu: ' + sLieu
                    + '\nCapacite: ' + (d.eventNbr || '') + ' places'
                    + '\nPayant: ' + (d.eventPaiement || '');

                try {
                    new QRCode(qrContainer, {
                        text: qrText,
                        width: 220,
                        height: 220,
                        colorDark: '#0d0d1a',
                        colorLight: '#ffffff',
                        correctLevel: QRCode.CorrectLevel.L
                    });
                } catch (e) {
                    // Fallback: try with minimal text
                    qrContainer.innerHTML = '';
                    try {
                        new QRCode(qrContainer, {
                            text: 'Participation #' + d.participationId + ' | ' + sNom,
                            width: 220,
                            height: 220,
                            colorDark: '#0d0d1a',
                            colorLight: '#ffffff',
                            correctLevel: QRCode.CorrectLevel.L
                        });
                    } catch (e2) {
                        qrContainer.innerHTML = '<p style="color:#f87171;"><i class="fas fa-exclamation-triangle me-1"></i>QR code indisponible</p>';
                    }
                }

                document.getElementById('qr-details').innerHTML =
                    '<h6 style="color:var(--gold);margin-bottom:.5rem;font-size:.95rem;border-bottom:1px solid var(--border);padding-bottom:.4rem;"><i class="fas fa-ticket-alt me-1"></i>Ma Participation</h6>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-hashtag me-1"></i>ID:</strong> #' + escapeHtml(d.participationId) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-calendar-day me-1"></i>Date d\'inscription:</strong> ' + escapeHtml(d.partDate) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-users me-1"></i>Places réservées:</strong> ' + escapeHtml(d.partNbr) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-check-circle me-1"></i>Statut:</strong> ' + escapeHtml(d.partStatut) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-credit-card me-1"></i>Paiement:</strong> ' + escapeHtml(d.partMode) + '</p>'
                    + '<hr style="border-color:var(--border);margin:.6rem 0;">'
                    + '<h6 style="color:var(--gold);margin-bottom:.5rem;font-size:.95rem;border-bottom:1px solid var(--border);padding-bottom:.4rem;"><i class="fas fa-calendar-alt me-1"></i>Événement</h6>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-bookmark me-1"></i>Nom:</strong> ' + escapeHtml(d.eventNom) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-tag me-1"></i>Type:</strong> ' + escapeHtml(d.eventType) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="far fa-calendar-alt me-1"></i>Date:</strong> ' + escapeHtml(d.eventDate) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="far fa-clock me-1"></i>Heure:</strong> ' + escapeHtml(d.eventHeure) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-map-marker-alt me-1"></i>Lieu:</strong> ' + escapeHtml(d.eventLieu) + '</p>'
                    + '<p><strong style="color:var(--gold)"><i class="fas fa-users me-1"></i>Capacité:</strong> ' + escapeHtml(d.eventNbr) + ' places</p>';

                qrModal.show();
            });
        });
    }

    /* Bind buttons on initial page load */
    bindCardButtons();

    /* ═══ AJAX FORM SUBMISSION (no page refresh on errors) ═══ */

    function clearFormErrors(formEl) {
        formEl.querySelectorAll('.is-invalid').forEach(function (el) {
            el.classList.remove('is-invalid');
        });
        formEl.querySelectorAll('.ajax-error').forEach(function (el) {
            el.remove();
        });
    }

    function showFieldError(formEl, fieldKey, message) {
        var inputMap = {
            'nbr_participation': formEl.querySelector('[name="nbr_participation"]'),
            'mode_paiement': formEl.querySelector('[name="mode_paiement"]'),
            'id_evenement': formEl.querySelector('[name="id_evenement"]'),
            'date': formEl.querySelector('[name="nbr_participation"]'),
            'date_participation': formEl.querySelector('[name="nbr_participation"]'),
            'general': formEl.querySelector('[name="nbr_participation"]'),
            'stripe': formEl.querySelector('[name="nbr_participation"]'),
            'statut': formEl.querySelector('[name="nbr_participation"]')
        };
        var input = inputMap[fieldKey] || formEl.querySelector('[name="nbr_participation"]');
        if (input) {
            input.classList.add('is-invalid');
            var errDiv = document.createElement('div');
            errDiv.className = 'ajax-error invalid-feedback d-block';
            errDiv.style.cssText = 'color:#f87171;font-size:0.875rem;margin-top:0.25rem;';
            errDiv.innerHTML = '<i class="fas fa-exclamation-circle me-1"></i>' + escapeHtml(message);
            input.parentNode.appendChild(errDiv);
        }
    }

    // ── Participate form (AJAX) ──
    var participateForm = document.getElementById('participateForm');
    if (participateForm) {
        participateForm.addEventListener('submit', function (e) {
            e.preventDefault();
            clearFormErrors(participateForm);

            var formData = new FormData(participateForm);
            var submitBtn = document.getElementById('pm-submit-btn');
            var originalHtml = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Traitement...';

            fetch(participateForm.action, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            })
            .then(function (res) { return res.json(); })
            .then(function (data) {
                if (data.success) {
                    // Redirect (Stripe or success)
                    window.location.href = data.redirect;
                } else {
                    // Show errors under inputs
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    if (data.errors) {
                        Object.keys(data.errors).forEach(function (key) {
                            showFieldError(participateForm, key, data.errors[key]);
                        });
                    }
                }
            })
            .catch(function () {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                showFieldError(participateForm, 'general', 'Une erreur est survenue. Veuillez réessayer.');
            });
        });
    }

    // ── Edit participation form (AJAX) ──
    var editForm = document.getElementById('editParticipationForm');
    if (editForm) {
        editForm.addEventListener('submit', function (e) {
            e.preventDefault();
            clearFormErrors(editForm);

            var formData = new FormData(editForm);
            var submitBtn = editForm.querySelector('.btn-submit');
            var originalHtml = submitBtn.innerHTML;
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<i class="fas fa-spinner fa-spin me-1"></i>Traitement...';

            fetch(editForm.action, {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            })
            .then(function (res) { return res.json(); })
            .then(function (data) {
                if (data.success) {
                    window.location.href = data.redirect;
                } else {
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalHtml;
                    if (data.errors) {
                        Object.keys(data.errors).forEach(function (key) {
                            showFieldError(editForm, key, data.errors[key]);
                        });
                    }
                }
            })
            .catch(function () {
                submitBtn.disabled = false;
                submitBtn.innerHTML = originalHtml;
                showFieldError(editForm, 'general', 'Une erreur est survenue. Veuillez réessayer.');
            });
        });
    }

    /* ── Auto-dismiss flash messages ── */
    document.querySelectorAll('.flash-msg').forEach(function (el) {
        setTimeout(function () {
            el.style.transition = 'opacity .4s, transform .4s';
            el.style.opacity = '0';
            el.style.transform = 'translateY(-8px)';
            setTimeout(function () { el.remove(); }, 400);
        }, 4000);
    });
});
</script>
{% endblock %}
