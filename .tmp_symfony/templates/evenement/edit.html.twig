{# ═══════════════════════════════════════════════════════════════
   Evenement – Modifier (Edit)
   Route: GET|POST /evenement/{id}/modifier
   PHP validation errors displayed per field
═══════════════════════════════════════════════════════════════ #}
{% extends 'base.html.twig' %}

{% block title %}Modifier – {{ evenement.nom }}{% endblock %}

{% block stylesheets %}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <style>
        :root {
            --gold: #d4af37; --gold-dark: #b8860b;
            --purple: #a855f7; --bg-dark: #0a0a0f;
            --bg-card: rgba(20,20,30,0.95); --border: rgba(212,175,55,0.15);
        }
        body { font-family: 'Poppins', sans-serif; background: var(--bg-dark); color: #e0e0e0; min-height: 100vh; }
        .page-header {
            background: linear-gradient(135deg, rgba(212,175,55,0.08), rgba(138,43,226,0.08));
            border-bottom: 1px solid var(--border); padding: 2rem 0; margin-bottom: 2rem;
        }
        .page-header h1 { color: #fff; font-weight: 700; }
        .form-card {
            background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; padding: 2.5rem; max-width: 800px; margin: 0 auto;
        }
        .form-card .form-label {
            color: rgba(255,255,255,0.8); font-weight: 600; font-size: 0.875rem;
            margin-bottom: 0.5rem;
        }
        .form-card .form-label .required { color: #ef4444; }
        .form-card .form-label i { color: var(--gold); margin-right: 0.375rem; }
        .form-card .form-control,
        .form-card .form-select {
            background: rgba(255,255,255,0.04);
            border: 1px solid rgba(255,255,255,0.1);
            color: #e0e0e0; border-radius: 8px;
            padding: 0.75rem 1rem; font-size: 0.9375rem;
            transition: all 0.3s;
        }
        .form-card .form-control:focus,
        .form-card .form-select:focus {
            background: rgba(255,255,255,0.06);
            border-color: var(--gold);
            box-shadow: 0 0 0 3px rgba(212,175,55,0.15);
            color: #fff;
        }
        .form-card .form-control.is-invalid,
        .form-card .form-select.is-invalid {
            border-color: #ef4444;
            box-shadow: 0 0 0 3px rgba(239,68,68,0.15);
        }
        .form-card .invalid-feedback {
            color: #ef4444; font-size: 0.8125rem; margin-top: 0.375rem;
            display: flex; align-items: center; gap: 0.375rem;
        }
        .form-card textarea { resize: vertical; min-height: 100px; }
        .form-card .form-select option { background: #1a1a2e; color: #e0e0e0; }
        .toggle-wrap {
            display: flex; align-items: center; justify-content: space-between;
            padding: 1rem 1.25rem; background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.08); border-radius: 10px;
        }
        .toggle-info { display: flex; align-items: center; gap: 0.75rem; }
        .toggle-info i { color: var(--gold); font-size: 1.25rem; }
        .toggle-info .title { font-weight: 600; color: #fff; font-size: 0.9375rem; }
        .toggle-info .desc { font-size: 0.8125rem; color: rgba(255,255,255,0.5); }
        .switch { position: relative; width: 52px; height: 28px; }
        .switch input { opacity: 0; width: 0; height: 0; }
        .slider {
            position: absolute; cursor: pointer; inset: 0;
            background: rgba(255,255,255,0.1); border-radius: 28px;
            transition: all 0.3s;
        }
        .slider::before {
            content: ''; position: absolute; width: 22px; height: 22px;
            left: 3px; bottom: 3px; background: #fff; border-radius: 50%;
            transition: all 0.3s;
        }
        .switch input:checked + .slider { background: var(--gold); }
        .switch input:checked + .slider::before { transform: translateX(24px); }
        .btn-gold {
            background: linear-gradient(135deg, var(--gold), var(--gold-dark));
            color: #0a0a0f; border: none; font-weight: 600;
            padding: 0.75rem 2rem; border-radius: 8px; font-size: 1rem;
            transition: all 0.3s;
        }
        .btn-gold:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(212,175,55,0.4); color: #0a0a0f; }
        .btn-outline-light { border-color: rgba(255,255,255,0.2); color: rgba(255,255,255,0.7); padding: 0.75rem 2rem; border-radius: 8px; }
        .btn-outline-light:hover { background: rgba(255,255,255,0.05); color: #fff; }
        .section-divider {
            height: 1px; background: linear-gradient(90deg, transparent, var(--border), transparent);
            margin: 1.5rem 0;
        }
        .id-badge {
            background: rgba(212,175,55,0.1); border: 1px solid rgba(212,175,55,0.3);
            color: var(--gold); padding: 0.375rem 0.75rem; border-radius: 6px;
            font-weight: 600; font-size: 0.875rem;
        }
    </style>
{% endblock %}

{% block body %}
    <div class="page-header">
        <div class="container">
            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                <div>
                    <h1 class="mb-1"><i class="fas fa-edit me-2" style="color: var(--gold);"></i>Modifier l'Événement</h1>
                    <nav aria-label="breadcrumb">
                        <ol class="breadcrumb mb-0" style="font-size: 0.875rem;">
                            <li class="breadcrumb-item"><a href="{{ path('app_evenement_index') }}" style="color: var(--gold); text-decoration: none;">Événements</a></li>
                            <li class="breadcrumb-item active text-muted">Modifier #{{ evenement.id }}</li>
                        </ol>
                    </nav>
                </div>
                <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-arrow-left me-1"></i> Retour à la liste
                </a>
            </div>
        </div>
    </div>

    <div class="container pb-5">
        <div class="form-card">
            <div class="d-flex align-items-center gap-2 mb-4">
                <span class="id-badge"><i class="fas fa-hashtag me-1"></i>ID: {{ evenement.id }}</span>
            </div>

            <form method="post" action="{{ path('app_evenement_edit', {id: evenement.id}) }}" enctype="multipart/form-data" novalidate>

                <div class="row g-3">
                    {# ── Nom ── #}
                    <div class="col-12">
                        <label class="form-label" for="nom">
                            <i class="fas fa-bookmark"></i> Nom de l'événement <span class="required">*</span>
                        </label>
                        <input type="text" name="nom" id="nom"
                               class="form-control {{ errors.nom is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('nom') : evenement.nom }}"
                               placeholder="Ex: Gala Night 2026">
                        {% if errors.nom is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.nom }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Type Événement ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="type_evenement">
                            <i class="fas fa-tags"></i> Type d'événement <span class="required">*</span>
                        </label>
                        {% set currentType = errors is not empty ? app.request.request.get('type_evenement') : evenement.typeEvenement %}
                        <select name="type_evenement" id="type_evenement"
                                class="form-select {{ errors.type_evenement is defined ? 'is-invalid' : '' }}">
                            <option value="" disabled>Sélectionner un type…</option>
                            {% for type in types %}
                                <option value="{{ type }}" {{ currentType == type ? 'selected' : '' }}>{{ type }}</option>
                            {% endfor %}
                        </select>
                        {% if errors.type_evenement is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.type_evenement }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Nombre de participants ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="nbr_participant">
                            <i class="fas fa-users"></i> Nombre de participants <span class="required">*</span>
                        </label>
                        <input type="number" name="nbr_participant" id="nbr_participant"
                               class="form-control {{ errors.nbr_participant is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('nbr_participant') : evenement.nbrParticipant }}"
                               min="1" placeholder="Ex: 150">
                        {% if errors.nbr_participant is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.nbr_participant }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Date ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="date">
                            <i class="fas fa-calendar-day"></i> Date <span class="required">*</span>
                        </label>
                        <input type="date" name="date" id="date"
                               class="form-control {{ errors.date is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('date') : evenement.date|date('Y-m-d') }}">
                        {% if errors.date is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.date }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Heure ── #}
                    <div class="col-md-6">
                        <label class="form-label" for="heure">
                            <i class="fas fa-clock"></i> Heure <span class="required">*</span>
                        </label>
                        <input type="time" name="heure" id="heure"
                               class="form-control {{ errors.heure is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('heure') : evenement.heure|date('H:i') }}">
                        {% if errors.heure is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.heure }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Lieu ── #}
                    <div class="col-12">
                        <label class="form-label" for="lieu">
                            <i class="fas fa-map-marker-alt"></i> Lieu <span class="required">*</span>
                        </label>
                        <input type="text" name="lieu" id="lieu"
                               class="form-control {{ errors.lieu is defined ? 'is-invalid' : '' }}"
                               value="{{ errors is not empty ? app.request.request.get('lieu') : evenement.lieu }}"
                               placeholder="Ex: Palais des Arts, Tunis">
                        {% if errors.lieu is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.lieu }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Description ── #}
                    <div class="col-12">
                        <label class="form-label" for="description">
                            <i class="fas fa-align-left"></i> Description <span class="required">*</span>
                        </label>
                        <textarea name="description" id="description" rows="4"
                                  class="form-control {{ errors.description is defined ? 'is-invalid' : '' }}"
                                  placeholder="Décrivez votre événement en détail…">{{ errors is not empty ? app.request.request.get('description') : evenement.description }}</textarea>
                        {% if errors.description is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.description }}
                            </div>
                        {% endif %}
                    </div>

                    {# ── Paiement Toggle ── #}
                    <div class="col-12">
                        <div class="toggle-wrap">
                            <div class="toggle-info">
                                <i class="fas fa-credit-card"></i>
                                <div>
                                    <div class="title">Événement payant</div>
                                    <div class="desc">Activez si l'événement nécessite un paiement</div>
                                </div>
                            </div>
                            {% set isPaid = errors is not empty ? app.request.request.has('paiement') : evenement.paiement %}
                            <label class="switch">
                                <input type="checkbox" name="paiement" value="1" {{ isPaid ? 'checked' : '' }}>
                                <span class="slider"></span>
                            </label>
                        </div>
                    </div>

                    {# ── Image Upload ── #}
                    <div class="col-12">
                        <label class="form-label" for="image">
                            <i class="fas fa-image"></i> Image de l'événement
                        </label>
                        {% if evenement.image %}
                            <div class="mb-2">
                                <img src="{{ asset('uploads/evenements/' ~ evenement.image) }}" alt="{{ evenement.nom }}"
                                     style="max-width: 200px; max-height: 150px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1);">
                                <small class="d-block mt-1" style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Image actuelle. Sélectionnez une nouvelle image pour la remplacer.</small>
                            </div>
                        {% endif %}
                        <input type="file" name="image" id="image" accept="image/*"
                               class="form-control {{ errors.image is defined ? 'is-invalid' : '' }}">
                        <small style="color: rgba(255,255,255,0.4); font-size: 0.8rem;">Formats acceptés : JPG, PNG, GIF, WEBP. Taille max : 5 Mo.</small>
                        {% if errors.image is defined %}
                            <div class="invalid-feedback d-block">
                                <i class="fas fa-exclamation-triangle"></i> {{ errors.image }}
                            </div>
                        {% endif %}
                    </div>
                </div>

                <div class="section-divider"></div>

                {# ── Actions ── #}
                <div class="d-flex justify-content-end gap-3">
                    <a href="{{ path('app_evenement_index') }}" class="btn btn-outline-light">
                        <i class="fas fa-times me-1"></i> Annuler
                    </a>
                    <button type="submit" class="btn btn-gold">
                        <i class="fas fa-save me-1"></i> Enregistrer les modifications
                    </button>
                </div>
            </form>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
{% endblock %}
