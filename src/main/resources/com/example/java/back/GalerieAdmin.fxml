<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.*?>

<BorderPane
        xmlns="http://javafx.com/javafx/17"
        xmlns:fx="http://javafx.com/fxml/1"
        fx:controller="com.example.java.controllers.GalerieController"
        styleClass="app-root">

    <top>
        <VBox>
            <!-- Page header -->
            <HBox spacing="16" styleClass="page-header">
                <padding><Insets top="22" right="26" bottom="22" left="26"/></padding>
                <VBox spacing="5" HBox.hgrow="ALWAYS">
                    <Label text="🖼️  Gestion des Galeries" styleClass="title"/>
                    <Label text="Ajoutez, modifiez ou supprimez vos galeries d'art" styleClass="subtitle"/>
                </VBox>
                <Button text="＋  Nouvelle Galerie"
                        onAction="#openAddDialog"
                        styleClass="btn-gold"/>
            </HBox>

            <!-- Barre de recherche -->
            <HBox spacing="12" styleClass="search-bar">
                <padding><Insets top="12" right="26" bottom="12" left="26"/></padding>
                <Label text="Recherche :" styleClass="search-label"/>
                <TextField fx:id="searchField"
                           promptText="Nom, catégorie..."
                           onKeyReleased="#onSearch"
                           styleClass="search-input"
                           HBox.hgrow="ALWAYS"/>
                <Button text="Rechercher" styleClass="btn-gold" onAction="#onSearch"/>
                <Button text="Effacer" styleClass="btn-ghost" onAction="#clearSearch"/>
            </HBox>

            <!-- Stats bar -->
            <HBox spacing="16" styleClass="stats-bar">
                <padding><Insets top="9" right="26" bottom="9" left="26"/></padding>
                <Label fx:id="totalLabel" text="Chargement..." styleClass="stats-count"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true"
                    styleClass="app-root"
                    style="-fx-background-color: #0b0b12; -fx-background: #0b0b12; -fx-border-width: 0;"
                    hbarPolicy="NEVER">
            <FlowPane fx:id="galerieContainer"
                      hgap="20" vgap="20"
                      styleClass="cards-container"
                      style="-fx-padding: 24; -fx-background-color: #0b0b12;"/>
        </ScrollPane>
    </center>

</BorderPane>
