<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="700.0" prefWidth="1000.0" styleClass="app-root" stylesheets="@styles/blog.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.UserListController">
    <children>
        <VBox spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <!-- header -->
                <HBox alignment="CENTER_LEFT" spacing="20.0" styleClass="navbar">
                    <children>
                        <Button mnemonicParsing="false" onAction="#retour" styleClass="btn-ghost" text="⬅" />
                        <VBox>
                            <children>
                                <Label styleClass="title" text="ADMINISTRATION" />
                                <Label styleClass="subtitle" text="Gestion des membres et modération des comptes" />
                            </children>
                        </VBox>
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10" styleClass="blog-input" prefWidth="300">
                            <children>
                                <Label text="🔍" />
                                <TextField fx:id="searchField" promptText="Rechercher un membre..." style="-fx-background-color: transparent; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <Button mnemonicParsing="false" onAction="#ouvrirAjouter" styleClass="btn-gold" text="+ MEMBRE" />
                    </children>
                </HBox>
                
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" VBox.vgrow="ALWAYS">
                    <content>
                        <FlowPane fx:id="userContainer" alignment="TOP_LEFT" hgap="20.0" vgap="20.0" style="-fx-padding: 20;">
                            <!-- User cards will be loaded here -->
                        </FlowPane>
                    </content>
                </ScrollPane>
            </children>
        </VBox>
    </children>
</AnchorPane>
