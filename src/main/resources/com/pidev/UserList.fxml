<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pidev.controllers.UserListController"
            prefHeight="600.0" prefWidth="900.0"
            style="-fx-background-color: #f4f4f4;">

    <!-- Titre -->
    <Label text="👥 Gestion des Utilisateurs"
           style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"
           AnchorPane.topAnchor="15" AnchorPane.leftAnchor="20"/>

    <!-- Barre recherche + tri -->
    <HBox spacing="10"
          AnchorPane.topAnchor="55" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20">

        <TextField fx:id="tfRecherche" promptText="🔍 Rechercher par nom, prénom ou email..."
                   prefWidth="350"
                   style="-fx-padding: 7;"/>

        <ComboBox fx:id="cbTri" promptText="Trier par..."
                  prefWidth="180"
                  style="-fx-padding: 4;"/>

        <Button text="🔍 Rechercher" onAction="#rechercher"
                style="-fx-background-color: #2980b9; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14;"/>

        <Button text="🔄 Réinitialiser" onAction="#reinitialiser"
                style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 7 14;"/>
    </HBox>

    <!-- Boutons CRUD -->
    <HBox spacing="10"
          AnchorPane.topAnchor="100" AnchorPane.leftAnchor="20">
        <Button text="➕ Ajouter" onAction="#ouvrirAjouter"
                style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16;"/>
        <Button text="✏️ Modifier" onAction="#ouvrirModifier"
                style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16;"/>
        <Button text="🗑️ Supprimer" onAction="#supprimer"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16;"/>
        <Button text="📋 Afficher tous" onAction="#afficherTous"
                style="-fx-background-color: #8e44ad; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 16;"/>
    </HBox>

    <!-- Compteur -->
    <Label fx:id="lblCompteur" text="Total : 0 utilisateur(s)"
           style="-fx-text-fill: #7f8c8d; -fx-font-size: 12;"
           AnchorPane.topAnchor="105" AnchorPane.rightAnchor="20"/>

    <!-- Tableau -->
    <TableView fx:id="tableUser"
               AnchorPane.topAnchor="140" AnchorPane.leftAnchor="20"
               AnchorPane.rightAnchor="20" AnchorPane.bottomAnchor="20">
        <columns>
            <TableColumn fx:id="colId"        text="ID"        prefWidth="50"/>
            <TableColumn fx:id="colNom"       text="Nom"       prefWidth="130"/>
            <TableColumn fx:id="colPrenom"    text="Prénom"    prefWidth="130"/>
            <TableColumn fx:id="colEmail"     text="Email"     prefWidth="220"/>
            <TableColumn fx:id="colTelephone" text="Téléphone" prefWidth="120"/>
            <TableColumn fx:id="colRole"      text="Rôle"      prefWidth="100"/>
        </columns>
    </TableView>

</AnchorPane>
