<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="600.0" prefWidth="900.0" styleClass="app-root" stylesheets="@styles/client.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.DashboardController">
    <children>
        <VBox alignment="CENTER" spacing="50.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <VBox alignment="CENTER" spacing="10.0">
                    <children>
                        <Label styleClass="title" text="TABLEAU DE BORD" />
                        <Label fx:id="welcomeLabel" style="-fx-text-fill: -fx-gold; -fx-font-size: 18;" text="Bienvenue, Utilisateur" />
                    </children>
                </VBox>
                
                <HBox alignment="CENTER" spacing="40.0">
                    <children>
                        <!-- User Management Card -->
                        <VBox alignment="CENTER" onMouseClicked="#ouvrirGestion" prefHeight="300.0" prefWidth="350.0" spacing="20.0" styleClass="publication-card" style="-fx-cursor: hand;">
                            <children>
                                <Label style="-fx-font-size: 60;" text="👥" />
                                <Label styleClass="publication-title" text="Gestion Utilisateurs" />
                                <Label alignment="CENTER" styleClass="subtitle" text="Gérez les comptes, les rôles et les membres de la plateforme." textAlignment="CENTER" wrapText="true" />
                                <Button mnemonicParsing="false" onAction="#ouvrirGestion" styleClass="btn-ghost" text="ACCÉDER" />
                            </children>
                        </VBox>
                        
                        <!-- Blog Management Card -->
                        <VBox alignment="CENTER" onMouseClicked="#ouvrirBlog" prefHeight="300.0" prefWidth="350.0" spacing="20.0" styleClass="publication-card" style="-fx-cursor: hand;">
                            <children>
                                <Label style="-fx-font-size: 60;" text="📰" />
                                <Label styleClass="publication-title" text="Premium Blog" />
                                <Label alignment="CENTER" styleClass="subtitle" text="Explorez les posts, interagissez avec la communauté et publiez vos articles." textAlignment="CENTER" wrapText="true" />
                                <Button mnemonicParsing="false" onAction="#ouvrirBlog" styleClass="btn-gold" text="EXPLORER" />
                            </children>
                        </VBox>
                    </children>
                </HBox>
                
                <Button mnemonicParsing="false" onAction="#seDeconnecter" styleClass="btn-ghost" style="-fx-text-fill: #ff6b6b;" text="SE DÉCONNECTER" />
            </children>
            <padding>
                <Insets bottom="50.0" left="50.0" right="50.0" top="50.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>
