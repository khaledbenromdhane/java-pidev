<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- ═══════════════════════════════════════════════════════════════
     Frontoffice – Participation Show (Detail View)
     Converted from: participation/show.html.twig
     ═══════════════════════════════════════════════════════════════ -->
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.controllers.ParticipationShowController"
            stylesheets="@/com/pidev/styles/admin.css" styleClass="app-root">
    <top>
        <HBox styleClass="page-header" spacing="16" alignment="CENTER_LEFT">
            <padding>
                <Insets top="24" right="32" bottom="24" left="32"/>
            </padding>
            <VBox spacing="6" HBox.hgrow="ALWAYS">
                <Label text="👁  Détails de la Participation" styleClass="page-title"/>
                <HBox spacing="6" alignment="CENTER_LEFT">
                    <Hyperlink text="Participations" onAction="#onBack"
                               style="-fx-text-fill: #d4af37; -fx-font-size: 12px; -fx-border-color: transparent;"/>
                    <Label text="›" styleClass="breadcrumb-label"/>
                    <Label fx:id="breadcrumbId" text="Participation #1" styleClass="breadcrumb-label"/>
                </HBox>
            </VBox>
            <Button text="← Retour à la liste" styleClass="btn-ghost" onAction="#onBack"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <VBox alignment="CENTER">
                <padding>
                    <Insets top="24" right="32" bottom="32" left="32"/>
                </padding>

                <VBox styleClass="detail-card" spacing="0" maxWidth="800">
                    <!-- ID Badge -->
                    <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 0 0 16 0;">
                        <Label fx:id="idBadge" text="# ID: 1" styleClass="id-badge"/>
                    </HBox>

                    <!-- Événement -->
                    <HBox styleClass="detail-row" spacing="16" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="📅" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Événement"/>
                        </HBox>
                        <Label fx:id="evenementValue" text="—" styleClass="badge-type"/>
                    </HBox>

                    <!-- Date Participation -->
                    <HBox styleClass="detail-row" spacing="16" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="📆" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Date de participation"/>
                        </HBox>
                        <Label fx:id="dateValue" text="—" styleClass="detail-value"/>
                    </HBox>

                    <!-- Nombre de places -->
                    <HBox styleClass="detail-row" spacing="16" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="👥" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Nombre de places"/>
                        </HBox>
                        <Label fx:id="nbrValue" text="—" styleClass="detail-value"/>
                    </HBox>

                    <!-- Statut -->
                    <HBox styleClass="detail-row" spacing="16" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="ℹ" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Statut"/>
                        </HBox>
                        <Label fx:id="statutValue" text="—" styleClass="badge-pending"/>
                    </HBox>

                    <!-- Mode de paiement -->
                    <HBox styleClass="detail-row" spacing="16" alignment="CENTER_LEFT">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="💳" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Mode de paiement"/>
                        </HBox>
                        <Label fx:id="paiementValue" text="—" styleClass="detail-value"/>
                    </HBox>

                    <!-- Lieu de l'événement -->
                    <HBox fx:id="lieuRow" styleClass="detail-row" spacing="16" alignment="CENTER_LEFT"
                          managed="false" visible="false">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="📍" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Lieu de l'événement"/>
                        </HBox>
                        <Label fx:id="lieuValue" text="—" styleClass="detail-value"/>
                    </HBox>

                    <!-- Date de l'événement -->
                    <HBox fx:id="evtDateRow" styleClass="detail-row" spacing="16" alignment="CENTER_LEFT"
                          managed="false" visible="false"
                          style="-fx-border-width: 0;">
                        <HBox spacing="6" alignment="CENTER_LEFT" styleClass="detail-label">
                            <Label text="📅" style="-fx-text-fill: #d4af37;"/>
                            <Label text="Date de l'événement"/>
                        </HBox>
                        <Label fx:id="evtDateValue" text="—" styleClass="detail-value"/>
                    </HBox>

                    <!-- Divider -->
                    <Separator style="-fx-background-color: rgba(255,255,255,0.06); -fx-padding: 16 0;"/>

                    <!-- Action Buttons -->
                    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 16 0 0 0;">
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="🗑 Supprimer" styleClass="btn-danger" onAction="#onDelete"/>
                        <Button text="✏ Modifier" styleClass="btn-admin-primary" onAction="#onEdit"/>
                    </HBox>
                </VBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
