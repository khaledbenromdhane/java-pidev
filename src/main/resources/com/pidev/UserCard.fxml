<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>

<VBox fx:id="cardContainer" prefWidth="300.0" spacing="15.0" styleClass="publication-card" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.UserCardController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15.0">
            <children>
                <StackPane>
                    <children>
                        <Circle fill="#2c3e50" radius="25.0" stroke="#d4af37" strokeType="INSIDE" />
                        <Label fx:id="avatarLabel" style="-fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 18;" text="U" />
                    </children>
                </StackPane>
                <VBox>
                    <children>
                        <Label fx:id="nameLabel" styleClass="publication-title" style="-fx-font-size: 16;" text="Nom Prénom" />
                        <Label fx:id="emailLabel" styleClass="subtitle" style="-fx-font-size: 11;" text="email@domain.com" />
                    </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="statusLabel" style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 3 8; -fx-font-size: 10;" text="ACTIVE" />
            </children>
        </HBox>
        
        <Separator opacity="0.1" />
        
        <HBox spacing="10">
            <children>
                <Label style="-fx-text-fill: grey; -fx-font-size: 12;" text="Rôle:" />
                <Label fx:id="roleLabel" style="-fx-text-fill: -fx-gold; -fx-font-weight: bold; -fx-font-size: 12;" text="Membre" />
            </children>
        </HBox>
        
        <HBox spacing="10">
            <children>
                <Label style="-fx-text-fill: grey; -fx-font-size: 12;" text="📞" />
                <Label fx:id="phoneLabel" style="-fx-text-fill: white; -fx-font-size: 12;" text="+216 00 000 000" />
            </children>
        </HBox>
        
        <HBox alignment="CENTER_RIGHT" spacing="10.0" style="-fx-padding: 10 0 0 0;">
            <children>
                <Button onAction="#handleEdit" styleClass="btn-ghost" style="-fx-font-size: 11; -fx-padding: 5 15;" text="Modifier" />
                <Button fx:id="banBtn" onAction="#handleBan" style="-fx-background-color: transparent; -fx-border-color: #ff6b6b; -fx-text-fill: #ff6b6b; -fx-border-radius: 10; -fx-padding: 5 15; -fx-font-size: 11; -fx-cursor: hand;" text="Bannir" />
            </children>
        </HBox>
    </children>
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>
</VBox>
