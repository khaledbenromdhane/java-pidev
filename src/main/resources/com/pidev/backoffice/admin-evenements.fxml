<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<!-- ═══════════════════════════════════════════════════════════════
     Admin Événements Management Page
     Converted from: admin/evenements.html.twig + admin/base.html.twig
     Theme: Dark luxury – gold/purple
     ═══════════════════════════════════════════════════════════════ -->
<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.controllers.AdminEvenementsController"
            stylesheets="@/com/pidev/styles/admin.css" styleClass="app-root">

    <!-- ══════════════════════════════════════════════════════════
         TOP NAVBAR
         ══════════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="admin-navbar" alignment="CENTER_LEFT" spacing="12">
            <!-- Brand -->
            <HBox alignment="CENTER_LEFT" spacing="6">
                <Label text="✦" style="-fx-text-fill: #d4af37; -fx-font-size: 18px;"/>
                <Label text="Artis" styleClass="brand-text"/>
                <Label text="Event" styleClass="brand-accent"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search -->
            <TextField styleClass="admin-search-input" promptText="Search…" prefWidth="220"/>

            <!-- Nav Icons -->
            <Button text="🔔" styleClass="nav-icon-btn"/>
            <Button text="✉" styleClass="nav-icon-btn"/>

            <!-- Profile -->
            <HBox alignment="CENTER" spacing="8" styleClass="admin-profile-btn">
                <Label text="👤" style="-fx-font-size: 16px;"/>
                <VBox spacing="1">
                    <Label text="Admin User" styleClass="admin-name"/>
                    <Label text="Administrateur" styleClass="admin-role"/>
                </VBox>
            </HBox>
        </HBox>
    </top>

    <!-- ══════════════════════════════════════════════════════════
         LEFT SIDEBAR
         ══════════════════════════════════════════════════════════ -->
    <left>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="admin-sidebar">
            <VBox spacing="2" styleClass="admin-sidebar">
                <!-- Main Menu -->
                <Label text="MAIN MENU" styleClass="sidebar-section-title"/>
                <Button text="  📊  Dashboard" styleClass="sidebar-link" maxWidth="Infinity"/>
                <Button text="  👥  Utilisateurs" styleClass="sidebar-link" maxWidth="Infinity"/>

                <!-- Événements (active) -->
                <Label text="  📅  Événements" styleClass="sidebar-link-active"
                       maxWidth="Infinity" style="-fx-padding: 10 14;"/>
                <Button fx:id="sidebarEvtLink" text="      📆 Événement" styleClass="sidebar-submenu-link" maxWidth="Infinity"
                        style="-fx-text-fill: #d4af37;"/>
                <Button fx:id="sidebarPartLink" text="      👥 Participation" styleClass="sidebar-submenu-link" maxWidth="Infinity"
                        onAction="#onNavigateParticipations"/>
                <Button text="      📱 Scanner QR" styleClass="sidebar-submenu-link" maxWidth="Infinity"/>

                <!-- Blogs -->
                <Button text="  🖊  Blogs" styleClass="sidebar-link" maxWidth="Infinity"/>
                <!-- Galerie -->
                <Button text="  🖼  Galerie" styleClass="sidebar-link" maxWidth="Infinity"/>
                <!-- Formation -->
                <Button text="  🎓  Formation" styleClass="sidebar-link" maxWidth="Infinity"/>

                <Separator style="-fx-background-color: rgba(255,255,255,0.06);"/>

                <!-- Compte -->
                <Label text="COMPTE" styleClass="sidebar-section-title"/>
                <Button text="  👤  Mon Profil" styleClass="sidebar-link" maxWidth="Infinity"/>
                <Button text="  ✏  Modifier le Profil" styleClass="sidebar-link" maxWidth="Infinity"/>
                <Button text="  🚪  Déconnexion" styleClass="sidebar-link sidebar-logout" maxWidth="Infinity"
                        style="-fx-text-fill: #dc3545;"/>

                <Separator style="-fx-background-color: rgba(255,255,255,0.06);"/>

                <!-- Settings -->
                <Label text="SETTINGS" styleClass="sidebar-section-title"/>
                <Button text="  📈  Analytics" styleClass="sidebar-link" maxWidth="Infinity"/>
                <Button text="  ⚙  Settings" styleClass="sidebar-link" maxWidth="Infinity"/>
            </VBox>
        </ScrollPane>
    </left>

    <!-- ══════════════════════════════════════════════════════════
         MAIN CONTENT
         ══════════════════════════════════════════════════════════ -->
    <center>
        <BorderPane>
            <!-- Page Header -->
            <top>
                <VBox>
                    <HBox styleClass="page-header" alignment="CENTER_LEFT" spacing="16">
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                            <Label text="Événements" styleClass="page-title"/>
                            <HBox spacing="6" alignment="CENTER_LEFT">
                                <Label text="🏠" styleClass="breadcrumb-active"/>
                                <Label text="›" styleClass="breadcrumb-label"/>
                                <Label text="Dashboard" styleClass="breadcrumb-active"/>
                                <Label text="›" styleClass="breadcrumb-label"/>
                                <Label text="Événements" styleClass="breadcrumb-label"/>
                            </HBox>
                        </VBox>
                        <HBox spacing="8">
                            <Button text="📤 Export" styleClass="btn-admin-outline" fx:id="exportBtn"/>
                            <Button text="📅 Add Événement" styleClass="btn-admin-primary"
                                    fx:id="addEventBtn" onAction="#onAddEvent"/>
                        </HBox>
                    </HBox>
                </VBox>
            </top>

            <!-- Scrollable content -->
            <center>
                <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                    <VBox spacing="16">
                        <padding>
                            <Insets top="20" right="24" bottom="24" left="24"/>
                        </padding>

                        <!-- ═══════════════════════════════════════
                             STAT SUMMARY CARDS
                             ═══════════════════════════════════════ -->
                        <HBox spacing="16">
                            <!-- Total Events -->
                            <HBox styleClass="stat-card" spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="📅" styleClass="stat-icon-gold"/>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="totalCountLabel" text="0" styleClass="stat-value"/>
                                    <Label text="Total Events" styleClass="stat-label"/>
                                </VBox>
                                <Label text="↑ 12%" styleClass="stat-trend-up"/>
                            </HBox>
                            <!-- Upcoming -->
                            <HBox styleClass="stat-card" spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="⏰" styleClass="stat-icon-purple"/>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="upcomingCountLabel" text="0" styleClass="stat-value"/>
                                    <Label text="Upcoming" styleClass="stat-label"/>
                                </VBox>
                                <Label text="↑ 8%" styleClass="stat-trend-up"/>
                            </HBox>
                            <!-- Total Attendees -->
                            <HBox styleClass="stat-card" spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="👥" styleClass="stat-icon-teal"/>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="totalAttendeesLabel" text="0" styleClass="stat-value"/>
                                    <Label text="Total Attendees" styleClass="stat-label"/>
                                </VBox>
                                <Label text="↑ 24%" styleClass="stat-trend-up"/>
                            </HBox>
                            <!-- Paid Events -->
                            <HBox styleClass="stat-card" spacing="14" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                <Label text="💰" styleClass="stat-icon-gold"/>
                                <VBox spacing="2" HBox.hgrow="ALWAYS">
                                    <Label fx:id="paidCountLabel" text="0" styleClass="stat-value"/>
                                    <Label text="Paid Events" styleClass="stat-label"/>
                                </VBox>
                                <Label text="↓ 3%" styleClass="stat-trend-down"/>
                            </HBox>
                        </HBox>

                        <!-- ═══════════════════════════════════════
                             EVENTS TABLE CARD
                             ═══════════════════════════════════════ -->
                        <VBox styleClass="admin-table-card" spacing="0">

                            <!-- Table Header with Filters -->
                            <HBox styleClass="table-header" spacing="12" alignment="CENTER_LEFT">
                                <HBox spacing="8" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="📅 All Événements" styleClass="table-title"/>
                                    <Label fx:id="evtCountBadge" text="0" styleClass="count-badge"/>
                                </HBox>
                                <TextField fx:id="searchField" styleClass="search-input"
                                           promptText="Search events…" prefWidth="200"/>
                                <ComboBox fx:id="typeFilter" styleClass="filter-select" promptText="All Types"
                                          prefWidth="140"/>
                                <ComboBox fx:id="paiementFilter" styleClass="filter-select" promptText="All Payment"
                                          prefWidth="130"/>
                                <Button text="🔍" styleClass="btn-admin-outline" onAction="#onSearch"
                                        style="-fx-padding: 6 12;"/>
                                <Button fx:id="resetBtn" text="✕" styleClass="btn-ghost" onAction="#onReset"
                                        style="-fx-padding: 6 10;"/>
                            </HBox>

                            <!-- Table -->
                            <TableView fx:id="eventsTable" VBox.vgrow="ALWAYS" prefHeight="420">
                                <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                                </columnResizePolicy>
                                <columns>
                                    <TableColumn fx:id="colId" text="#" prefWidth="70" sortable="true"/>
                                    <TableColumn fx:id="colNom" text="Nom" prefWidth="180" sortable="true"/>
                                    <TableColumn fx:id="colType" text="Type" prefWidth="140" sortable="true"/>
                                    <TableColumn fx:id="colParticipants" text="Participants" prefWidth="100" sortable="true"/>
                                    <TableColumn fx:id="colDate" text="Date" prefWidth="110" sortable="true"/>
                                    <TableColumn fx:id="colHeure" text="Heure" prefWidth="80" sortable="true"/>
                                    <TableColumn fx:id="colLieu" text="Lieu" prefWidth="140" sortable="true"/>
                                    <TableColumn fx:id="colPaiement" text="Paiement" prefWidth="100" sortable="true"/>
                                    <TableColumn fx:id="colActions" text="Actions" prefWidth="130" sortable="false"/>
                                </columns>
                            </TableView>

                            <!-- Table Footer / Pagination -->
                            <HBox styleClass="table-footer" spacing="8" alignment="CENTER">
                                <HBox spacing="4" alignment="CENTER_LEFT" HBox.hgrow="ALWAYS">
                                    <Label text="Showing " styleClass="footer-info"/>
                                    <Label fx:id="showingCount" text="0" styleClass="footer-info-bold"/>
                                    <Label text=" of " styleClass="footer-info"/>
                                    <Label fx:id="totalEvtCount" text="0" styleClass="footer-info-bold"/>
                                    <Label text=" events" styleClass="footer-info"/>
                                </HBox>
                                <HBox spacing="4" alignment="CENTER_RIGHT">
                                    <Button text="‹" styleClass="page-btn page-btn-disabled"/>
                                    <Button text="1" styleClass="page-btn page-btn-active"/>
                                    <Button text="2" styleClass="page-btn"/>
                                    <Button text="3" styleClass="page-btn"/>
                                    <Button text="…" styleClass="page-btn"/>
                                    <Button text="27" styleClass="page-btn"/>
                                    <Button text="›" styleClass="page-btn"/>
                                </HBox>
                            </HBox>
                        </VBox>

                    </VBox>
                </ScrollPane>
            </center>

            <!-- Footer -->
            <bottom>
                <HBox styleClass="admin-footer" alignment="CENTER" spacing="16">
                    <HBox spacing="4" HBox.hgrow="ALWAYS">
                        <Label text="© 2026 " styleClass="footer-text"/>
                        <Label text="Tun'Arche" styleClass="footer-accent"/>
                        <Label text=". All rights reserved." styleClass="footer-text"/>
                    </HBox>
                    <Label text="Crafted with ♥ for Arts &amp; Events" styleClass="footer-text"/>
                </HBox>
            </bottom>
        </BorderPane>
    </center>
</BorderPane>
