<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.pidev.controllers.AdminDashboardController"
            prefHeight="750.0" prefWidth="1150.0"
            style="-fx-background-color: #f8faff;">

    <!-- SIDEBAR -->
    <left>
        <VBox prefWidth="240" style="-fx-background-color: #0f172a;">
            <VBox alignment="CENTER" style="-fx-padding: 28 20; -fx-background-color: #1e293b;">
                <Label text="PIDEV ADMIN"
                       style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="Panneau d'administration"
                       style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
            </VBox>
            <VBox alignment="CENTER" spacing="4"
                  style="-fx-padding: 20; -fx-background-color: #1e293b;
                         -fx-border-color: #334155; -fx-border-width: 1 0 1 0;">
                <Label text="&#128081;" style="-fx-font-size: 28;"/>
                <Label fx:id="lblAdminNom" text="Admin"
                       style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: white;"/>
                <Label text="ADMINISTRATEUR"
                       style="-fx-font-size: 10; -fx-text-fill: #f59e0b; -fx-font-weight: bold;"/>
            </VBox>
            <VBox spacing="4" style="-fx-padding: 20 12;">
                <Label text="MENU"
                       style="-fx-font-size: 10; -fx-text-fill: #475569;
                              -fx-font-weight: bold; -fx-padding: 0 8 8 8;"/>
                <Button text="  Dashboard" onAction="#afficherStats"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1a56db; -fx-text-fill: white;
                               -fx-font-size: 13; -fx-padding: 11 16;
                               -fx-alignment: CENTER-LEFT; -fx-background-radius: 8;"/>
                <Button text="  Utilisateurs" onAction="#afficherUsers"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1;
                               -fx-font-size: 13; -fx-padding: 11 16;
                               -fx-alignment: CENTER-LEFT; -fx-background-radius: 8;"/>
                <Button text="  Mon Profil" onAction="#allerProfil"
                        maxWidth="Infinity"
                        style="-fx-background-color: transparent; -fx-text-fill: #cbd5e1;
                               -fx-font-size: 13; -fx-padding: 11 16;
                               -fx-alignment: CENTER-LEFT; -fx-background-radius: 8;"/>
            </VBox>
            <Region VBox.vgrow="ALWAYS"/>
            <VBox spacing="8" style="-fx-padding: 15 12;">
                <Button text="  Retour Accueil" onAction="#retourAccueil"
                        maxWidth="Infinity"
                        style="-fx-background-color: #1e293b; -fx-text-fill: #94a3b8;
                               -fx-font-size: 12; -fx-padding: 10 16;
                               -fx-alignment: CENTER-LEFT; -fx-background-radius: 8;
                               -fx-border-color: #334155; -fx-border-radius: 8;"/>
                <Button text="  Deconnexion" onAction="#deconnecter"
                        maxWidth="Infinity"
                        style="-fx-background-color: #7f1d1d; -fx-text-fill: white;
                               -fx-font-size: 12; -fx-padding: 10 16;
                               -fx-alignment: CENTER-LEFT; -fx-background-radius: 8;"/>
            </VBox>
        </VBox>
    </left>

    <!-- CONTENU -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: transparent; -fx-background: transparent;">
            <VBox spacing="20" style="-fx-padding: 28;">

                <!-- Header -->
                <HBox alignment="CENTER_LEFT">
                    <VBox>
                        <Label fx:id="lblBienvenue" text="Tableau de bord"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <Label fx:id="lblDate" text=""
                               style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Exporter PDF" onAction="#exporterPDF"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-padding: 10 22; -fx-background-radius: 10;"/>
                </HBox>

                <!-- Cartes stats -->
                <HBox spacing="14">
                    <VBox alignment="CENTER" prefWidth="165" prefHeight="90"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="&#128101;" style="-fx-font-size: 22;"/>
                        <Label fx:id="lblStatTotal" text="0"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #1a56db;"/>
                        <Label text="Total" style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="165" prefHeight="90"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="&#128081;" style="-fx-font-size: 22;"/>
                        <Label fx:id="lblStatAdmin" text="0"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                        <Label text="Admins" style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="165" prefHeight="90"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="&#128100;" style="-fx-font-size: 22;"/>
                        <Label fx:id="lblStatUser" text="0"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                        <Label text="Utilisateurs" style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="165" prefHeight="90"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="&#128222;" style="-fx-font-size: 22;"/>
                        <Label fx:id="lblStatAvecTel" text="0"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                        <Label text="Avec Tel" style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
                    </VBox>
                    <VBox alignment="CENTER" prefWidth="165" prefHeight="90"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 16;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="&#128235;" style="-fx-font-size: 22;"/>
                        <Label fx:id="lblStatGmail" text="0"
                               style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                        <Label text="Gmail" style="-fx-font-size: 10; -fx-text-fill: #64748b;"/>
                    </VBox>
                </HBox>

                <!-- PieChart + Barres côte à côte -->
                <HBox spacing="20">

                    <!-- PieChart -->
                    <VBox prefWidth="420"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 20;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="Repartition des roles"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>
                        <PieChart fx:id="pieChart" prefHeight="280" legendVisible="true"
                                  labelsVisible="true"/>
                    </VBox>

                    <!-- Barres pourcentages -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white; -fx-background-radius: 14;
                                 -fx-border-color: #e2e8f0; -fx-border-radius: 14;
                                 -fx-border-width: 1; -fx-padding: 24;
                                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 3);">
                        <Label text="Statistiques en detail"
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #0f172a;"/>

                        <!-- ADMIN -->
                        <VBox spacing="5">
                            <HBox>
                                <Label text="Administrateurs"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctAdmin" text="0%"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #f59e0b;"/>
                            </HBox>
                            <StackPane prefHeight="12"
                                       style="-fx-background-color: #fef3c7; -fx-background-radius: 6;">
                                <HBox alignment="CENTER_LEFT">
                                    <Region fx:id="barAdmin" prefHeight="12"
                                            style="-fx-background-color: #f59e0b; -fx-background-radius: 6;"/>
                                </HBox>
                            </StackPane>
                        </VBox>

                        <!-- USER -->
                        <VBox spacing="5">
                            <HBox>
                                <Label text="Utilisateurs simples"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctUser" text="0%"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #22c55e;"/>
                            </HBox>
                            <StackPane prefHeight="12"
                                       style="-fx-background-color: #dcfce7; -fx-background-radius: 6;">
                                <HBox alignment="CENTER_LEFT">
                                    <Region fx:id="barUser" prefHeight="12"
                                            style="-fx-background-color: #22c55e; -fx-background-radius: 6;"/>
                                </HBox>
                            </StackPane>
                        </VBox>

                        <!-- AVEC TEL -->
                        <VBox spacing="5">
                            <HBox>
                                <Label text="Avec telephone"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctTel" text="0%"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #8b5cf6;"/>
                            </HBox>
                            <StackPane prefHeight="12"
                                       style="-fx-background-color: #ede9fe; -fx-background-radius: 6;">
                                <HBox alignment="CENTER_LEFT">
                                    <Region fx:id="barTel" prefHeight="12"
                                            style="-fx-background-color: #8b5cf6; -fx-background-radius: 6;"/>
                                </HBox>
                            </StackPane>
                        </VBox>

                        <!-- GMAIL -->
                        <VBox spacing="5">
                            <HBox>
                                <Label text="Comptes Gmail"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #374151;"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctGmail" text="0%"
                                       style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #ef4444;"/>
                            </HBox>
                            <StackPane prefHeight="12"
                                       style="-fx-background-color: #fee2e2; -fx-background-radius: 6;">
                                <HBox alignment="CENTER_LEFT">
                                    <Region fx:id="barGmail" prefHeight="12"
                                            style="-fx-background-color: #ef4444; -fx-background-radius: 6;"/>
                                </HBox>
                            </StackPane>
                        </VBox>

                    </VBox>
                </HBox>

                <!-- Barre CRUD -->
                <HBox spacing="10" alignment="CENTER_LEFT"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-padding: 14 18; -fx-border-color: #e2e8f0;
                             -fx-border-radius: 12; -fx-border-width: 1;">
                    <TextField fx:id="tfRecherche" promptText="Rechercher un utilisateur..."
                               prefWidth="280"
                               style="-fx-background-color: #f8faff; -fx-border-color: #e2e8f0;
                                      -fx-border-radius: 8; -fx-padding: 8 12; -fx-font-size: 13;"/>
                    <ComboBox fx:id="cbTri" prefWidth="160" style="-fx-font-size: 12;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Ajouter" onAction="#ouvrirAjouter"
                            style="-fx-background-color: #1a56db; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 12;
                                   -fx-padding: 9 18; -fx-background-radius: 8;"/>
                    <Button text="Modifier" onAction="#ouvrirModifier"
                            style="-fx-background-color: #f59e0b; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 12;
                                   -fx-padding: 9 18; -fx-background-radius: 8;"/>
                    <Button text="Supprimer" onAction="#supprimer"
                            style="-fx-background-color: #ef4444; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 12;
                                   -fx-padding: 9 18; -fx-background-radius: 8;"/>
                    <Button text="Actualiser" onAction="#actualiser"
                            style="-fx-background-color: #f1f5f9; -fx-text-fill: #475569;
                                   -fx-font-size: 12; -fx-padding: 9 14; -fx-background-radius: 8;"/>
                </HBox>

                <Label fx:id="lblCompteur" text="Chargement..."
                       style="-fx-font-size: 12; -fx-text-fill: #64748b;"/>

                <!-- Tableau -->
                <VBox prefHeight="260"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #e2e8f0; -fx-border-radius: 12; -fx-border-width: 1;">
                    <TableView fx:id="tableUser" prefHeight="260" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="colId"        text="ID"        prefWidth="55"/>
                            <TableColumn fx:id="colNom"       text="Nom"       prefWidth="130"/>
                            <TableColumn fx:id="colPrenom"    text="Prenom"    prefWidth="130"/>
                            <TableColumn fx:id="colEmail"     text="Email"     prefWidth="220"/>
                            <TableColumn fx:id="colTelephone" text="Telephone" prefWidth="120"/>
                            <TableColumn fx:id="colRole"      text="Role"      prefWidth="100"/>
                        </columns>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
