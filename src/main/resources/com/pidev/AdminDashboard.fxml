<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.chart.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.shape.Circle?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.controllers.AdminDashboardController"
            prefWidth="1100" prefHeight="700"
            style="-fx-background-color: #0d0d0f;">

    <!-- ===== TOP NAVBAR ===== -->
    <top>
        <HBox alignment="CENTER_LEFT" prefHeight="58"
              style="-fx-background-color: #111114; -fx-border-color: #2a2a35;
                     -fx-border-width: 0 0 1 0; -fx-padding: 0 20 0 0;">

            <HBox alignment="CENTER_LEFT" spacing="10" prefWidth="255"
                  style="-fx-padding: 0 0 0 18; -fx-border-color: #2a2a35; -fx-border-width: 0 1 0 0;">
                <StackPane prefWidth="32" prefHeight="32"
                           style="-fx-background-color: #f0b429; -fx-background-radius: 7;">
                    <Label text="T" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a1000;"/>
                </StackPane>
                <Label text="Tun'Arche"
                       style="-fx-font-family: 'Georgia'; -fx-font-size: 19; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                <Region HBox.hgrow="ALWAYS"/>
            </HBox>



            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER" spacing="9" style="-fx-padding: 0 0 0 14;">
                <Circle fx:id="circleAdminAvatar" radius="20" fill="#333333" stroke="#f0b429" strokeWidth="1"/>
                <VBox spacing="1" alignment="CENTER_LEFT">
                    <Label fx:id="lblAdminNom" text="Administrateur"
                           style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                    <Label text="Administrateur" style="-fx-font-size: 10; -fx-text-fill: #666677;"/>
                </VBox>
            </HBox>
        </HBox>
    </top>

    <!-- ===== SIDEBAR ===== -->
    <left>
        <VBox prefWidth="255" spacing="0"
              style="-fx-background-color: #111114; -fx-border-color: #2a2a35; -fx-border-width: 0 1 0 0;">

            <VBox style="-fx-padding: 22 0 8 0;">
                <Label text="MAIN MENU"
                       style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #444455;
                              -fx-padding: 0 20 10 20;"/>

                <!-- afficherStats() ✓ -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-background-color: #c8891a; -fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#afficherStats">
                    <Label text="&#9783;" style="-fx-font-size: 15; -fx-text-fill: #ffffff;"/>
                    <Label text="Dashboard"
                           style="-fx-font-size: 13; -fx-text-fill: #ffffff; -fx-font-weight: bold;"/>
                </HBox>

                <!-- afficherUsers() ✓ -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#afficherUsers">
                    <Label text="&#128101;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Utilisateurs" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"/>
                </HBox>

                <!-- Evenements (pas encore implémenté – désactivé) -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-opacity: 0.35;">
                    <Label text="&#128197;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Evenements" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                    <Label text="&#9660;" style="-fx-font-size: 10; -fx-text-fill: #444455;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-opacity: 0.35;">
                    <Label text="&#9998;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Blogs" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                    <Label text="&#9660;" style="-fx-font-size: 10; -fx-text-fill: #444455;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-opacity: 0.35;">
                    <Label text="&#128444;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Galerie" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                    <Label text="&#9660;" style="-fx-font-size: 10; -fx-text-fill: #444455;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-opacity: 0.35;">
                    <Label text="&#127891;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Formation" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                    <Label text="&#9660;" style="-fx-font-size: 10; -fx-text-fill: #444455;"/>
                </HBox>
            </VBox>

            <VBox style="-fx-padding: 14 0 8 0;">
                <Label text="COMPTE"
                       style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #444455;
                              -fx-padding: 0 20 10 20;"/>

                <!-- allerProfil() ✓ -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#allerProfil">
                    <Label text="&#128100;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Mon Profil" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"/>
                </HBox>

                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#allerProfil">
                    <Label text="&#9998;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Modifier le Profil" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"/>
                </HBox>

                <!-- deconnecter() ✓ -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#deconnecter">
                    <Label text="&#10140;" style="-fx-font-size: 14; -fx-text-fill: #e84040;"/>
                    <Label text="Deconnexion"
                           style="-fx-font-size: 13; -fx-text-fill: #e84040; -fx-font-weight: bold;"/>
                </HBox>
            </VBox>

            <Region VBox.vgrow="ALWAYS"/>

            <VBox style="-fx-padding: 0 0 14 0; -fx-border-color: #2a2a35; -fx-border-width: 1 0 0 0;">
                <Label text="SETTINGS"
                       style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #444455;
                              -fx-padding: 14 20 10 20;"/>
                <!-- actualiser() ✓ -->
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-cursor: hand;"
                      onMouseClicked="#actualiser">
                    <Label text="&#128200;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Analytics" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"/>
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="12" prefHeight="44"
                      style="-fx-padding: 0 20; -fx-opacity: 0.35;">
                    <Label text="&#9881;" style="-fx-font-size: 14; -fx-text-fill: #888899;"/>
                    <Label text="Settings" style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"/>
                </HBox>
            </VBox>

        </VBox>
    </left>

    <!-- ===== CONTENU CENTRAL ===== -->
    <center>
        <ScrollPane fitToWidth="true"
                    style="-fx-background-color: #0d0d0f; -fx-border-color: transparent;">
            <VBox spacing="20" style="-fx-background-color: #0d0d0f; -fx-padding: 26 28;">

                <!-- Titre -->
                <VBox spacing="4">
                    <Label fx:id="lblBienvenue" text="Tableau de bord"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                    <HBox spacing="6" alignment="CENTER_LEFT">
                        <Label text="&#127968;" style="-fx-font-size: 11; -fx-text-fill: #444455;"/>
                        <Label text="›" style="-fx-font-size: 11; -fx-text-fill: #444455;"/>
                        <Label fx:id="lblDate" text=""
                               style="-fx-font-size: 11; -fx-text-fill: #666677;"/>
                    </HBox>
                </VBox>

                <!-- ── 5 STAT CARDS ── -->
                <HBox spacing="12">
                    <VBox spacing="5" prefWidth="168" prefHeight="90"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 16 16;">
                        <Label text="TOTAL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #555566;"/>
                        <Label fx:id="lblStatTotal" text="—"
                               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f0b429;"/>
                    </VBox>
                    <VBox spacing="5" prefWidth="168" prefHeight="90"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 16 16;">
                        <Label text="ADMINS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #555566;"/>
                        <Label fx:id="lblStatAdmin" text="—"
                               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f0b429;"/>
                    </VBox>
                    <VBox spacing="5" prefWidth="168" prefHeight="90"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 16 16;">
                        <Label text="UTILISATEURS" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #555566;"/>
                        <Label fx:id="lblStatUser" text="—"
                               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f0b429;"/>
                    </VBox>
                    <VBox spacing="5" prefWidth="168" prefHeight="90"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 16 16;">
                        <Label text="AVEC TEL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #555566;"/>
                        <Label fx:id="lblStatAvecTel" text="—"
                               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f0b429;"/>
                    </VBox>
                    <VBox spacing="5" prefWidth="168" prefHeight="90"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 16 16;">
                        <Label text="GMAIL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #555566;"/>
                        <Label fx:id="lblStatGmail" text="—"
                               style="-fx-font-size: 30; -fx-font-weight: bold; -fx-text-fill: #f0b429;"/>
                    </VBox>
                </HBox>

                <!-- ── BARRES + PIE ── -->
                <HBox spacing="16" alignment="TOP_LEFT">

                    <!-- Barres -->
                    <VBox spacing="18" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 22 22;">
                        <Label text="Repartition en detail"
                               style="-fx-font-size: 13; -fx-font-weight: bold; -fx-text-fill: #f0f0f0; -fx-padding: 0 0 4 0;"/>

                        <VBox spacing="5">
                            <HBox>
                                <Label text="Admins" style="-fx-font-size: 12; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctAdmin" text="0%"
                                       style="-fx-font-size: 12; -fx-text-fill: #f0b429; -fx-font-weight: bold;"/>
                            </HBox>
                            <StackPane alignment="CENTER_LEFT" prefHeight="9" maxWidth="350"
                                       style="-fx-background-color: #2a2a35; -fx-background-radius: 5;">
                                <Region fx:id="barAdmin" prefHeight="9" prefWidth="0"
                                        style="-fx-background-color: #f0b429; -fx-background-radius: 5;"
                                        StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <VBox spacing="5">
                            <HBox>
                                <Label text="Utilisateurs" style="-fx-font-size: 12; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctUser" text="0%"
                                       style="-fx-font-size: 12; -fx-text-fill: #4a80d4; -fx-font-weight: bold;"/>
                            </HBox>
                            <StackPane alignment="CENTER_LEFT" prefHeight="9" maxWidth="350"
                                       style="-fx-background-color: #2a2a35; -fx-background-radius: 5;">
                                <Region fx:id="barUser" prefHeight="9" prefWidth="0"
                                        style="-fx-background-color: #4a80d4; -fx-background-radius: 5;"
                                        StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <VBox spacing="5">
                            <HBox>
                                <Label text="Avec telephone" style="-fx-font-size: 12; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctTel" text="0%"
                                       style="-fx-font-size: 12; -fx-text-fill: #8b5cf6; -fx-font-weight: bold;"/>
                            </HBox>
                            <StackPane alignment="CENTER_LEFT" prefHeight="9" maxWidth="350"
                                       style="-fx-background-color: #2a2a35; -fx-background-radius: 5;">
                                <Region fx:id="barTel" prefHeight="9" prefWidth="0"
                                        style="-fx-background-color: #8b5cf6; -fx-background-radius: 5;"
                                        StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>

                        <VBox spacing="5">
                            <HBox>
                                <Label text="Gmail" style="-fx-font-size: 12; -fx-text-fill: #ccccdd;" HBox.hgrow="ALWAYS"/>
                                <Label fx:id="lblPctGmail" text="0%"
                                       style="-fx-font-size: 12; -fx-text-fill: #e84040; -fx-font-weight: bold;"/>
                            </HBox>
                            <StackPane alignment="CENTER_LEFT" prefHeight="9" maxWidth="350"
                                       style="-fx-background-color: #2a2a35; -fx-background-radius: 5;">
                                <Region fx:id="barGmail" prefHeight="9" prefWidth="0"
                                        style="-fx-background-color: #e84040; -fx-background-radius: 5;"
                                        StackPane.alignment="CENTER_LEFT"/>
                            </StackPane>
                        </VBox>
                    </VBox>

                    <!-- PieChart -->
                    <VBox prefWidth="300"
                          style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-background-radius: 10; -fx-border-radius: 10; -fx-padding: 22 16;">
                        <PieChart fx:id="pieChart" prefHeight="230" prefWidth="280"
                                  style="-fx-background-color: transparent;"
                                  labelsVisible="true" legendVisible="false"/>
                    </VBox>

                </HBox>

                <!-- ── TABLE UTILISATEURS ── -->
                <VBox spacing="0"
                      style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                             -fx-background-radius: 10; -fx-border-radius: 10;">

                    <VBox spacing="14" style="-fx-padding: 18 20 16 20; -fx-border-color: #2a2a35; -fx-border-width: 0 0 1 0;">
                        <!-- Ligne du titre et compteur -->
                        <HBox alignment="CENTER_LEFT" spacing="10">
                            <Label text="Liste des utilisateurs"
                                   style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                            <Label fx:id="lblCompteur" text=""
                                   style="-fx-font-size: 12; -fx-text-fill: #888899; -fx-padding: 2 0 0 0;"/>
                        </HBox>

                        <!-- Ligne des contrôles et actions -->
                        <HBox alignment="CENTER_LEFT" spacing="12">
                            
                            <!-- Barre de recherche -->
                            <HBox alignment="CENTER_LEFT" spacing="8"
                                  style="-fx-background-color: #111114; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                         -fx-background-radius: 6; -fx-border-radius: 6; -fx-padding: 6 12;" prefWidth="260">
                                <Label text="&#128269;" style="-fx-font-size: 12; -fx-text-fill: #555566;"/>
                                <TextField fx:id="tfRecherche" promptText="Rechercher..."
                                           style="-fx-background-color: transparent; -fx-border-color: transparent;
                                                  -fx-font-size: 12; -fx-text-fill: #e0e0e0; -fx-prompt-text-fill: #555566;"
                                           prefWidth="220" HBox.hgrow="ALWAYS"/>
                            </HBox>

                            <!-- Tri -->
                            <ComboBox fx:id="cbTri" prefWidth="180"
                                      style="-fx-background-color: #111114; -fx-border-color: #2a2a35; -fx-text-fill: #e0e0e0;
                                             -fx-border-radius: 6; -fx-background-radius: 6; -fx-font-size: 12;"/>
                            
                            <Region HBox.hgrow="ALWAYS"/>
                            
                            <!-- Boutons d'action -->
                            <Button text="Actualiser" onAction="#actualiser"
                                    style="-fx-background-color: #2a2a35; -fx-text-fill: #e0e0e0; -fx-font-size: 12;
                                           -fx-padding: 7 14; -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-border-color: transparent;"/>
                            <Button text="Modifier" onAction="#ouvrirModifier"
                                    style="-fx-background-color: transparent; -fx-text-fill: #f0b429; -fx-font-size: 12;
                                           -fx-padding: 7 14; -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-border-color: #f0b429; -fx-border-width: 1; -fx-border-radius: 6;"/>
                            <Button text="Supprimer" onAction="#supprimer"
                                    style="-fx-background-color: transparent; -fx-text-fill: #e84040; -fx-font-size: 12;
                                           -fx-padding: 7 14; -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-border-color: #e84040; -fx-border-width: 1; -fx-border-radius: 6;"/>
                            <Button text="Export PDF" onAction="#exporterPDF"
                                    style="-fx-background-color: transparent; -fx-text-fill: #22c55e; -fx-font-size: 12;
                                           -fx-padding: 7 14; -fx-background-radius: 6; -fx-cursor: hand;
                                           -fx-border-color: #22c55e; -fx-border-width: 1; -fx-border-radius: 6;"/>
                            <Button text="+ Ajouter" onAction="#ouvrirAjouter"
                                    style="-fx-background-color: #f0b429; -fx-text-fill: #1a1000; -fx-font-size: 12;
                                           -fx-font-weight: bold; -fx-padding: 7 16; -fx-background-radius: 6;
                                           -fx-cursor: hand; -fx-border-color: transparent;"/>
                        </HBox>
                    </VBox>

                    <TableView fx:id="tableUser" prefHeight="300"
                               style="-fx-background-color: transparent; -fx-border-color: transparent;
                                      -fx-table-cell-border-color: #2a2a35;">
                        <columns>
                            <TableColumn fx:id="colNom"       text="Nom"       prefWidth="140"/>
                            <TableColumn fx:id="colPrenom"    text="Prenom"    prefWidth="140"/>
                            <TableColumn fx:id="colEmail"     text="Email"     prefWidth="220"/>
                            <TableColumn fx:id="colTelephone" text="Telephone" prefWidth="130"/>
                            <TableColumn fx:id="colRole"      text="Role"      prefWidth="100"/>
                        </columns>
                        <placeholder>
                            <Label text="Aucun utilisateur trouve"
                                   style="-fx-font-size: 13; -fx-text-fill: #555566;"/>
                        </placeholder>
                    </TableView>
                </VBox>

            </VBox>
        </ScrollPane>
    </center>

    <!-- ===== FOOTER ===== -->
    <bottom>
        <HBox alignment="CENTER_LEFT" prefHeight="34"
              style="-fx-background-color: #111114; -fx-border-color: #2a2a35;
                     -fx-border-width: 1 0 0 0; -fx-padding: 0 24;">
            <Label text="© 2026 " style="-fx-font-size: 11; -fx-text-fill: #444455;"/>
            <Label text="Tun'Arche" style="-fx-font-size: 11; -fx-text-fill: #f0b429; -fx-font-weight: bold;"/>
            <Label text=". All rights reserved." style="-fx-font-size: 11; -fx-text-fill: #444455;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Crafted with ♥ for Arts &amp; Events"
                   style="-fx-font-size: 11; -fx-text-fill: #444455;"/>
        </HBox>
    </bottom>

</BorderPane>
