<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.controllers.EvenementListController"
            stylesheets="@/com/pidev/styles/evenement.css" styleClass="app-root">
    <top>
        <VBox>
            <HBox spacing="16" styleClass="page-header">
                <padding>
                    <Insets top="24" right="24" bottom="24" left="24"/>
                </padding>
                <VBox spacing="6" HBox.hgrow="ALWAYS">
                    <Label text="Événements" styleClass="title"/>
                    <Label text="Gérez tous les événements de la plateforme" styleClass="subtitle"/>
                </VBox>
                <Button text="Ajouter un Événement" styleClass="btn-gold" onAction="#onAdd"/>
            </HBox>
            <HBox spacing="12" styleClass="search-bar">
                <padding>
                    <Insets top="12" right="24" bottom="12" left="24"/>
                </padding>
                <Label text="Recherche:" styleClass="subtitle"/>
                <TextField fx:id="searchField" promptText="Nom, lieu, type, description..." styleClass="search-input" HBox.hgrow="ALWAYS"/>
                <Button text="Rechercher" styleClass="btn-gold" onAction="#onSearch"/>
                <Button text="Effacer" styleClass="btn-ghost" onAction="#onReset"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <StackPane>
            <padding>
                <Insets top="16" right="16" bottom="16" left="16"/>
            </padding>
            <VBox styleClass="card" spacing="8">
                <padding>
                    <Insets top="12" right="12" bottom="12" left="12"/>
                </padding>
                <TableView fx:id="table">
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                    </columnResizePolicy>
                    <columns>
                        <TableColumn fx:id="colId" text="#" prefWidth="60"/>
                        <TableColumn fx:id="colNom" text="Nom" prefWidth="180"/>
                        <TableColumn fx:id="colType" text="Type" prefWidth="140"/>
                        <TableColumn fx:id="colParticipants" text="Participants" prefWidth="120"/>
                        <TableColumn fx:id="colDate" text="Date" prefWidth="110"/>
                        <TableColumn fx:id="colHeure" text="Heure" prefWidth="90"/>
                        <TableColumn fx:id="colLieu" text="Lieu" prefWidth="160"/>
                        <TableColumn fx:id="colPaiement" text="Paiement" prefWidth="110"/>
                        <TableColumn fx:id="colDescription" text="Description" prefWidth="220"/>
                        <TableColumn fx:id="colActions" text="Actions" prefWidth="120"/>
                    </columns>
                </TableView>
            </VBox>
        </StackPane>
    </center>
</BorderPane>
