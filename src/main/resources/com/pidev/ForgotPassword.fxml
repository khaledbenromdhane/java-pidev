<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.pidev.controllers.ForgotPasswordController"
           prefWidth="430" prefHeight="550"
           style="-fx-background-color: #0d0d0f;">

    <VBox alignment="CENTER" spacing="0" style="-fx-padding: 30;">

        <VBox alignment="CENTER" spacing="0" maxWidth="370"
              style="-fx-background-color: #111114; -fx-border-color: #2a2a35; -fx-border-width: 1;
                     -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 30;">

            <!-- Header -->
            <VBox spacing="6" alignment="CENTER" style="-fx-padding: 0 0 25 0;">
                <Label text="Mot de passe oublié"
                       style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                <Label text="Récupérez l'accès à votre compte"
                       style="-fx-font-size: 12; -fx-text-fill: #555566;"/>
            </VBox>

            <!-- Step 1: Email -->
            <VBox fx:id="step1" spacing="15" alignment="CENTER_LEFT" maxWidth="Infinity">
                <VBox spacing="7">
                    <Label text="VOTRE EMAIL" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                    <TextField fx:id="tfEmail" promptText="votre@email.com"
                               style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                      -fx-font-size: 13; -fx-padding: 10 12;"
                               prefHeight="40" maxWidth="Infinity"/>
                </VBox>
                <Button text="ENVOYER LE CODE" onAction="#envoyerCode"
                        maxWidth="Infinity" prefHeight="42"
                        style="-fx-background-color: #f0b429; -fx-text-fill: #1a1000; -fx-font-size: 12;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <!-- Step 2: Code & New Password -->
            <VBox fx:id="step2" spacing="15" alignment="CENTER_LEFT" maxWidth="Infinity" managed="false" visible="false">
                <VBox spacing="7">
                    <Label text="CODE DE VÉRIFICATION" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                    <TextField fx:id="tfCode" promptText="Entrez le code à 6 chiffres"
                               style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                      -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                      -fx-font-size: 13; -fx-padding: 10 12;"
                               prefHeight="40" maxWidth="Infinity"/>
                </VBox>
                <VBox spacing="7">
                    <Label text="NOUVEAU MOT DE PASSE" style="-fx-font-size: 10; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                    <PasswordField fx:id="pfNewPassword" promptText="••••••••"
                                   style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                          -fx-font-size: 13; -fx-padding: 10 12;"
                                   prefHeight="40" maxWidth="Infinity"/>
                </VBox>
                <Button text="RÉINITIALISER LE MOT DE PASSE" onAction="#reinitialiserMdp"
                        maxWidth="Infinity" prefHeight="42"
                        style="-fx-background-color: #f0b429; -fx-text-fill: #1a1000; -fx-font-size: 12;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>
            </VBox>

            <!-- Message -->
            <Label fx:id="lblMessage" text=""
                   style="-fx-font-size: 11; -fx-padding: 15 0 0 0; -fx-wrap-text: true;"
                   maxWidth="Infinity" alignment="CENTER"/>

            <!-- Retour -->
            <Button text="Retour à la connexion" onAction="#retourConnexion"
                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                           -fx-text-fill: #555566; -fx-font-size: 12; -fx-cursor: hand; -fx-padding: 15 0 0 0;"/>

        </VBox>
    </VBox>
</StackPane>
