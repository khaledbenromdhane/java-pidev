<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.pidev.controllers.RegisterController"
            style="-fx-background-color: #0d0d0f; -fx-border-color: transparent;"
            prefWidth="1100" prefHeight="700">

    <VBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #0d0d0f; -fx-padding: 0 0 50 0;">

        <!-- ===== NAVBAR ===== -->
        <HBox alignment="CENTER_LEFT" spacing="0"
              style="-fx-background-color: #111114; -fx-border-color: #2a2a35;
                     -fx-border-width: 0 0 1 0; -fx-padding: 0 40;"
              prefHeight="64">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <StackPane prefWidth="32" prefHeight="32"
                           style="-fx-background-color: #f0b429; -fx-background-radius: 7;">
                    <Label text="T" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #1a1000;"/>
                </StackPane>
                <Label text="Tun'Arche"
                       style="-fx-font-family: 'Georgia'; -fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #f0f0f0; -fx-padding: 0 50 0 0;"/>
            </HBox>
            <HBox spacing="32" alignment="CENTER">
                <Label text="WELCOME" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
                <Label text="ABOUT" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
                <Label text="EXHIBITIONS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
                <Label text="EVENTS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
                <Label text="SHOP" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
                <Label text="CONTACT" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #888899;"/>
            </HBox>
        </HBox>

        <!-- ===== CARD ===== -->
        <VBox alignment="CENTER" style="-fx-padding: 40 0 0 0;">
            <VBox spacing="0"
                  style="-fx-background-color: #1a1a20; -fx-border-color: #2a2a35; -fx-border-width: 1;
                         -fx-background-radius: 12; -fx-border-radius: 12; -fx-padding: 44 50 48 50;"
                  maxWidth="720">

                <VBox spacing="6" style="-fx-padding: 0 0 32 0;" alignment="CENTER">
                    <Label text="Creer votre compte"
                           style="-fx-font-family: 'Georgia'; -fx-font-size: 26; -fx-font-weight: bold; -fx-text-fill: #f0f0f0;"/>
                    <Label text="Rejoignez la communaute Tun'Arche"
                           style="-fx-font-size: 13; -fx-text-fill: #555566;"/>
                </VBox>

                <!-- Nom + Prenom -->
                <HBox spacing="18" style="-fx-padding: 0 0 18 0;">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="NOM" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <TextField fx:id="tfNom" promptText="Votre nom"
                                   style="-fx-background-color: #0d0d0f; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                          -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 14;"
                                   prefHeight="44"/>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="PRENOM" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <TextField fx:id="tfPrenom" promptText="Votre prenom"
                                   style="-fx-background-color: #0d0d0f; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                          -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 14;"
                                   prefHeight="44"/>
                    </VBox>
                </HBox>

                <!-- Email + Tel -->
                <HBox spacing="18" style="-fx-padding: 0 0 18 0;">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="E-MAIL" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <TextField fx:id="tfEmail" promptText="exemple@email.com"
                                   style="-fx-background-color: #0d0d0f; -fx-border-color: #f0b429; -fx-border-width: 1.5;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                          -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 14;"
                                   prefHeight="44"/>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="TELEPHONE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <TextField fx:id="tfTelephone" promptText="+216 XX XXX XXX"
                                   style="-fx-background-color: #0d0d0f; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                          -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                          -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 14;"
                                   prefHeight="44"/>
                    </VBox>
                </HBox>

                <!-- Password and Confirm Password -->
                <HBox spacing="18" style="-fx-padding: 0 0 18 0;">
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="MOT DE PASSE" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <StackPane>
                            <PasswordField fx:id="pfPassword" promptText="Min. 4 caracteres"
                                           style="-fx-background-color: #0d0d0f; -fx-border-color: #f0b429; -fx-border-width: 1.5;
                                                  -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                                  -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 44 11 14;"
                                           prefHeight="44" maxWidth="Infinity"/>
                            <Button fx:id="togglePasswordBtn" text="&#128065;"
                                    style="-fx-background-color: transparent; -fx-border-color: transparent;
                                           -fx-font-size: 15; -fx-cursor: hand; -fx-text-fill: #c8753a;"
                                    StackPane.alignment="CENTER_RIGHT">
                                <StackPane.margin><Insets right="12"/></StackPane.margin>
                            </Button>
                        </StackPane>
                    </VBox>
                    <VBox spacing="7" HBox.hgrow="ALWAYS">
                        <Label text="CONFIRMER" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                        <PasswordField fx:id="pfConfirmPassword" promptText="Répéter le mot de passe"
                                       style="-fx-background-color: #0d0d0f; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                              -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #f0f0f0;
                                              -fx-prompt-text-fill: #333344; -fx-font-size: 13; -fx-padding: 11 14;"
                                       prefHeight="44" maxWidth="Infinity"/>
                    </VBox>
                </HBox>

                <!-- Role -->
                <VBox spacing="7" style="-fx-padding: 0 0 22 0;">
                    <Label text="JE SUIS" style="-fx-font-size: 11; -fx-font-weight: bold; -fx-text-fill: #aaaacc;"/>
                    <VBox style="-fx-background-color: #0d0d0f; -fx-border-color: #2a2a35; -fx-border-width: 1;
                                 -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 14 18;" spacing="10">
                        <RadioButton fx:id="rbUser" text="Utilisateur" selected="true"
                                     style="-fx-font-size: 13; -fx-text-fill: #ccccdd;">
                            <toggleGroup><ToggleGroup fx:id="roleGroup"/></toggleGroup>
                        </RadioButton>
                        <RadioButton fx:id="rbArtiste" text="Artiste"
                                     style="-fx-font-size: 13; -fx-text-fill: #ccccdd;"
                                     toggleGroup="$roleGroup"/>
                    </VBox>
                </VBox>

                <!-- CGU -->
                <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 0 0 20 0;">
                    <CheckBox fx:id="cbTermes" style="-fx-padding: 0;"/>
                    <HBox spacing="5" alignment="CENTER_LEFT">
                        <Label text="J'accepte les" style="-fx-font-size: 13; -fx-text-fill: #666677;"/>
                        <Hyperlink text="conditions d'utilisation"
                                   style="-fx-font-size: 13; -fx-text-fill: #f0b429; -fx-border-color: transparent; -fx-padding: 0;"/>
                    </HBox>
                </HBox>

                <!-- Message -->
                <Label fx:id="lblMessage" text=""
                       style="-fx-font-size: 12; -fx-padding: 0 0 12 0;"
                       maxWidth="Infinity" wrapText="true"/>

                <!-- Bouton -->
                <Button fx:id="btnCreer" text="CREER MON COMPTE" onAction="#sInscrire"
                        maxWidth="Infinity" prefHeight="50"
                        style="-fx-background-color: #c8753a; -fx-text-fill: #ffffff; -fx-font-size: 13;
                               -fx-font-weight: bold; -fx-background-radius: 8; -fx-cursor: hand;"/>

                <!-- Login link -->
                <HBox alignment="CENTER" spacing="6" style="-fx-padding: 18 0 0 0;">
                    <Label text="Deja un compte ?" style="-fx-font-size: 13; -fx-text-fill: #555566;"/>
                    <Button text="Se connecter" onAction="#ouvrirLogin"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;
                                   -fx-text-fill: #f0b429; -fx-font-size: 13; -fx-font-weight: bold;
                                   -fx-cursor: hand; -fx-padding: 0;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Footer -->
        <HBox alignment="CENTER" spacing="4" style="-fx-padding: 30 0 0 0;">
            <Label text="© 2026 " style="-fx-font-size: 11; -fx-text-fill: #333344;"/>
            <Label text="Tun'Arche" style="-fx-font-size: 11; -fx-text-fill: #f0b429; -fx-font-weight: bold;"/>
            <Label text=". All rights reserved." style="-fx-font-size: 11; -fx-text-fill: #333344;"/>
        </HBox>
    </VBox>
</ScrollPane>
