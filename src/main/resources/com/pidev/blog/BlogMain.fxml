<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.effect.*?>

<AnchorPane prefHeight="900.0" prefWidth="1200.0" styleClass="app-root" stylesheets="@../styles/client.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.blog.BlogMainController">
   <children>
      <VBox layoutX="0.0" layoutY="0.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <!-- Navigation Bar with Blur Effect -->
            <HBox alignment="CENTER_LEFT" spacing="30.0" styleClass="navbar">
               <children>
                  <VBox spacing="-5">
                     <children>
                        <Label styleClass="title" text="TUNARCHE" />
                        <Label style="-fx-text-fill: -fx-gold; -fx-font-weight: bold; -fx-letter-spacing: 2;" text="PREMIUM BLOG" />
                     </children>
                  </VBox>
                  
                  <Region HBox.hgrow="ALWAYS" />
                  
                  <HBox alignment="CENTER" spacing="15">
                     <children>
                        <Button fx:id="allPostsBtn" mnemonicParsing="false" styleClass="nav-link" text="EXPLORER" />
                        <Button fx:id="myPostsBtn" mnemonicParsing="false" styleClass="nav-link" text="MES POSTS" />
                     </children>
                  </HBox>
                  
                  <Separator orientation="VERTICAL" prefHeight="40" opacity="0.1" />
                  
                  <Button fx:id="addPostBtn" mnemonicParsing="false" styleClass="btn-gold" text="NOUVEAU POST" />
               </children>
            </HBox>
            
            <HBox VBox.vgrow="ALWAYS">
                <children>
                    <!-- Left Column: Navigation Glass Pane -->
                    <VBox prefWidth="280" spacing="30" style="-fx-padding: 40 25;">
                        <children>
                            <VBox spacing="20" styleClass="glass-pane" style="-fx-padding: 25;">
                                <children>
                                    <Label text="FILTRES" style="-fx-text-fill: -fx-gold; -fx-font-weight: 900; -fx-font-size: 12;" />
                                    <VBox spacing="12">
                                        <children>
                                            <Hyperlink text="🔥 Plus Populaires" />
                                            <Hyperlink text="⏰ Récents" />
                                            <Hyperlink text="💎 Favoris" />
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                            
                            <VBox spacing="20" styleClass="glass-pane" style="-fx-padding: 25; -fx-background-color: linear-gradient(to bottom, rgba(212,175,55,0.1), transparent);">
                                <children>
                                    <Label text="VOTRE ESPACE" style="-fx-font-weight: 900; -fx-font-size: 12;" />
                                    <Label text="Personnalisez votre profil et gérez vos publications." style="-fx-text-fill: grey;" wrapText="true" />
                                    <Button prefWidth="Infinity" styleClass="btn-gold" style="-fx-font-size: 12;" text="MON PROFIL" />
                                </children>
                            </VBox>
                        </children>
                    </VBox>

                    <!-- Main Feed -->
                    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;" HBox.hgrow="ALWAYS">
                       <content>
                          <VBox fx:id="feedContainer" alignment="TOP_CENTER" spacing="40.0" style="-fx-padding: 40 100;">
                             <children>
                                <HBox fx:id="adminBanner" alignment="CENTER" managed="false" spacing="10" style="-fx-background-color: rgba(212,175,55,0.1); -fx-border-color: -fx-gold; -fx-border-width: 1; -fx-border-radius: 10; -fx-padding: 15; -fx-background-radius: 10;" visible="false">
                                   <children>
                                      <Label style="-fx-font-size: 18;" text="🛡️" />
                                      <Label style="-fx-font-weight: 900;" text="MODE MODÉRATION ACTIVÉ" />
                                      <Label style="-fx-text-fill: -fx-gold; -fx-font-size: 11;" text="(Vous pouvez gérer toutes les publications et commentaires)" />
                                   </children>
                                   <VBox.margin>
                                      <Insets bottom="20" />
                                   </VBox.margin>
                                </HBox>
                             </children>
                             <!-- Modern Publication cards will be loaded here -->
                          </VBox>
                       </content>
                    </ScrollPane>
                    
                    <!-- Right Column: Community & Trends -->
                    <VBox prefWidth="320" spacing="30" style="-fx-padding: 40 30;">
                        <children>
                            <HBox alignment="CENTER" spacing="10" styleClass="blog-input">
                                <children>
                                    <Label text="🔍" />
                                    <TextField fx:id="searchField" promptText="Rechercher..." style="-fx-background-color: transparent;" HBox.hgrow="ALWAYS" />
                                </children>
                            </HBox>
                            
                            <VBox spacing="20" styleClass="glass-pane" style="-fx-padding: 25;">
                                <children>
                                    <Label text="TENDANCES" style="-fx-text-fill: -fx-gold; -fx-font-weight: 900; -fx-font-size: 12;" />
                                    <VBox spacing="15">
                                        <children>
                                            <VBox>
                                                <children>
                                                    <Label text="#Esprit3A" style="-fx-font-weight: bold;" />
                                                    <Label text="1.2k posts" style="-fx-text-fill: grey; -fx-font-size: 11;" />
                                                </children>
                                            </VBox>
                                            <VBox>
                                                <children>
                                                    <Label text="#TunarcheDev" style="-fx-font-weight: bold;" />
                                                    <Label text="856 posts" style="-fx-text-fill: grey; -fx-font-size: 11;" />
                                                </children>
                                            </VBox>
                                        </children>
                                    </VBox>
                                </children>
                            </VBox>
                        </children>
                    </VBox>
                </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
