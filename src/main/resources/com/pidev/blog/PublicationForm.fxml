<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane style="-fx-background-color: transparent;" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.blog.PublicationFormController">
    <children>
        <VBox spacing="30" styleClass="form-card" stylesheets="@../styles/blog.css" prefWidth="550.0" AnchorPane.bottomAnchor="20" AnchorPane.leftAnchor="20" AnchorPane.rightAnchor="20" AnchorPane.topAnchor="20">
            <children>
                <VBox spacing="5">
                    <children>
                        <Label styleClass="title" style="-fx-font-size: 28;" text="Nouveau Post" />
                        <Label style="-fx-text-fill: -fx-gold;" text="Partagez vos idées avec le monde" />
                    </children>
                </VBox>
                
                <VBox spacing="10">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="TITRE DE LA PUBLICATION" />
                        <TextField fx:id="titreField" promptText="Un titre accrocheur..." styleClass="blog-input" />
                        <Label fx:id="titreError" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11;" visible="false" />
                    </children>
                </VBox>
                
                <VBox spacing="10">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="CONTENU" />
                        <TextArea fx:id="descArea" prefHeight="200.0" promptText="Écrivez votre texte ici..." styleClass="blog-input" wrapText="true" />
                        <Label fx:id="descError" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11;" visible="false" />
                    </children>
                </VBox>
                
                <VBox spacing="10">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-weight: bold;" text="URL DE L'IMAGE PRINCIPALE" />
                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <children>
                                <TextField fx:id="imageField" HBox.hgrow="ALWAYS" promptText="Lien vers l'image..." styleClass="blog-input" />
                                <Button fx:id="uploadBtn" mnemonicParsing="false" onAction="#handleUpload" styleClass="btn-ghost" text="📁" />
                            </children>
                        </HBox>
                        <Label fx:id="imageError" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11;" visible="false" />
                    </children>
                </VBox>
                
                <HBox spacing="20" alignment="CENTER_RIGHT">
                    <children>
                        <Button fx:id="cancelBtn" mnemonicParsing="false" styleClass="btn-ghost" text="ANNULER" />
                        <Button fx:id="saveBtn" mnemonicParsing="false" styleClass="btn-gold" text="PUBLIER MAINTENANT" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</AnchorPane>
