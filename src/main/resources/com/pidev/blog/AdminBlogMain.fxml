<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<AnchorPane prefHeight="800.0" prefWidth="1200.0" style="-fx-background-color: #0f172a;" stylesheets="@../styles/blog.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.blog.AdminBlogController">
    <children>
        <BorderPane AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <top>
                <HBox alignment="CENTER_LEFT" spacing="20.0" style="-fx-background-color: #1e293b; -fx-padding: 15; -fx-border-color: #d4af37; -fx-border-width: 0 0 3 0;">
                    <children>
                        <Label style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;" text="🛡️ ESPACE MODÉRATION" />
                        <Region HBox.hgrow="ALWAYS" />
                        <HBox alignment="CENTER" spacing="10" style="-fx-background-color: #334155; -fx-background-radius: 10; -fx-padding: 5 15;" prefWidth="350">
                            <children>
                                <Label text="🔍" />
                                <TextField fx:id="searchField" promptText="Rechercher une publication..." style="-fx-background-color: transparent; -fx-text-fill: white;" HBox.hgrow="ALWAYS" />
                            </children>
                        </HBox>
                        <ComboBox fx:id="sortCombo" prefWidth="180.0" promptText="Trier par..." style="-fx-background-color: #334155; -fx-text-fill: white;" />
                        <Button mnemonicParsing="false" onAction="#ouvrirAjouter" style="-fx-background-color: #d4af37; -fx-text-fill: black; -fx-font-weight: bold; -fx-border-radius: 5; -fx-background-radius: 5; -fx-padding: 5 15;" text="➕ CRÉER" />
                        <Button mnemonicParsing="false" onAction="#retour" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-border-color: white; -fx-border-radius: 5;" text="QUITTER" />
                    </children>
                </HBox>
            </top>
            <center>
                <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-background: transparent;">
                    <content>
                        <VBox fx:id="feedContainer" alignment="TOP_CENTER" spacing="40.0" style="-fx-padding: 40 100;">
                            <children>
                                <HBox alignment="CENTER" spacing="15" style="-fx-background-color: rgba(212,175,55,0.05); -fx-border-color: #d4af37; -fx-border-width: 1; -fx-border-radius: 15; -fx-padding: 20; -fx-background-radius: 15;">
                                    <children>
                                       <Label style="-fx-font-size: 24;" text="🛡️" />
                                       <VBox>
                                          <children>
                                             <Label style="-fx-text-fill: white; -fx-font-weight: 900; -fx-font-size: 16;" text="CONTRÔLE TOTAL DU CONTENU" />
                                             <Label style="-fx-text-fill: #d4af37; -fx-font-size: 12;" text="Vous visualisez toutes les publications du système. Toute action est définitive." />
                                          </children>
                                       </VBox>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                    </content>
                </ScrollPane>
            </center>
        </BorderPane>
    </children>
</AnchorPane>
