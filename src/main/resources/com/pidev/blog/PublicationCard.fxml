<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<VBox fx:id="cardContainer" maxWidth="700.0" prefWidth="650.0" spacing="20" styleClass="publication-card" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.pidev.controllers.blog.PublicationCardController">
    <children>
        <HBox alignment="CENTER_LEFT" spacing="15">
            <children>
                <!-- Avatar Placeholder -->
                <StackPane prefHeight="45.0" prefWidth="45.0" style="-fx-background-color: -fx-gold; -fx-background-radius: 50;">
                    <children>
                        <Label fx:id="avatarInitial" style="-fx-text-fill: -fx-bg-dark; -fx-font-weight: bold; -fx-font-size: 18;" text="U" />
                    </children>
                </StackPane>
                
                <VBox HBox.hgrow="ALWAYS">
                    <children>
                        <Label fx:id="usernameLabel" style="-fx-font-weight: bold; -fx-font-size: 16;" text="Utilisateur" />
                        <Label fx:id="dateLabel" styleClass="subtitle" text="16 Avril 2026 • 11:45" />
                    </children>
                </VBox>
                
                <Button fx:id="showQrBtn" mnemonicParsing="false" styleClass="btn-ghost" text="Voir QR" />
                <Button fx:id="translateAllBtn" mnemonicParsing="false" styleClass="btn-ghost" text="Traduire tout" />
                
                <MenuButton fx:id="optionsBtn" mnemonicParsing="false" styleClass="btn-ghost" style="-fx-padding: 5 10;" text="•••">
                  <items>
                    <MenuItem fx:id="modifierItem" mnemonicParsing="false" text="Modifier" />
                    <MenuItem fx:id="supprimerItem" mnemonicParsing="false" text="Supprimer" />
                  </items>
                </MenuButton>
            </children>
        </HBox>

        <VBox spacing="10">
            <children>
                <Label fx:id="titreLabel" styleClass="publication-title" text="Titre de la Publication" wrapText="true" />
                <TextFlow lineSpacing="5.0">
                    <children>
                        <Text fx:id="descriptionText" styleClass="publication-description" text="Voici le contenu détaillé de la publication. Vous pouvez y mettre du texte riche et des détails sur votre aventure." />
                    </children>
                </TextFlow>
            </children>
        </VBox>
        
        <StackPane fx:id="imageFrame" styleClass="image-container">
            <children>
                <ImageView fx:id="publicationImage" fitHeight="350" fitWidth="600" pickOnBounds="true" preserveRatio="true" />
            </children>
        </StackPane>
        
        <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-padding: 10 0;">
            <children>
                <Button fx:id="likeBtn" mnemonicParsing="false" styleClass="reaction-btn" text="👍 0" />
                <Button fx:id="dislikeBtn" mnemonicParsing="false" styleClass="reaction-btn" text="👎 0" />
                <Region HBox.hgrow="ALWAYS" />
                <HBox alignment="CENTER" spacing="5">
                    <children>
                        <Label text="💬" />
                        <Label fx:id="commentCountLabel" styleClass="subtitle" style="-fx-font-size: 14;" text="0 Commentaires" />
                    </children>
                </HBox>
            </children>
        </HBox>
        
        <Separator opacity="0.1" />
        
        <VBox fx:id="commentsSection" spacing="15">
            <children>
                <VBox fx:id="commentsContainer" spacing="12">
                    <!-- Dynamic Comments -->
                </VBox>
                
                <VBox spacing="4">
                    <children>
                        <HBox spacing="10" alignment="CENTER">
                            <children>
                                <TextField fx:id="commentInput" HBox.hgrow="ALWAYS" promptText="Écrire un commentaire..." styleClass="blog-input" />
                                <Button fx:id="sendCommentBtn" mnemonicParsing="false" styleClass="btn-gold" text="PUBLIER" />
                            </children>
                        </HBox>
                        <HBox spacing="8" alignment="CENTER_LEFT" style="-fx-padding: 4 0 0 0;">
                            <children>
                                <Label style="-fx-text-fill: white; -fx-font-size: 12;" text="Emoji:" />
                                <Button fx:id="emojiSmileBtn" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 16; -fx-font-size: 14;" text="😀" />
                                <Button fx:id="emojiHeartBtn" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 16; -fx-font-size: 14;" text="❤️" />
                                <Button fx:id="emojiFireBtn" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 16; -fx-font-size: 14;" text="🔥" />
                                <Button fx:id="emojiSadBtn" mnemonicParsing="false" style="-fx-background-color: rgba(255,255,255,0.08); -fx-background-radius: 16; -fx-font-size: 14;" text="😢" />
                            </children>
                        </HBox>
                        <Label fx:id="commentError" managed="false" style="-fx-text-fill: #ff6b6b; -fx-font-size: 11;" visible="false" wrapText="true" />
                    </children>
                </VBox>
            </children>
        </VBox>
    </children>
</VBox>
